    </owl:NamedIndividual>
    


    <!-- https://ontology.lotusim.org/naval-maritime#UnidentifiedDebris -->


    <owl:NamedIndividual rdf:about="https://ontology.lotusim.org/naval-maritime#UnidentifiedDebris">
