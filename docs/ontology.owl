    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/modified -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/modified"/>
    


    <!-- http://purl.org/dc/terms/publisher -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/publisher"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#closeMatch -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#closeMatch"/>
    


    <!-- https://ontology.lotusim.org/naval-maritime#manifestKey -->


    <owl:AnnotationProperty rdf:about="https://ontology.lotusim.org/naval-maritime#manifestKey">
        <rdfs:comment xml:lang="fr">Identifiant normatif de famille d&apos;actions typées dans les manifestes de capacités (contrat supervision-guidage, LSGA v3 §4.3). Notation pointée famille.action. Les manifestes des autonomies référencent ces clés définies par l&apos;ontologie ; ils n&apos;en créent jamais.</rdfs:comment>
        <rdfs:label xml:lang="fr">clé de manifeste</rdfs:label>
        <rdfs:label xml:lang="en">manifest key</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:AnnotationProperty>
    


