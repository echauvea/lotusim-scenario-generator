    </owl:NamedIndividual>
    


    <!-- https://ontology.lotusim.org/naval-maritime#WaterVolume -->


    <owl:NamedIndividual rdf:about="https://ontology.lotusim.org/naval-maritime#WaterVolume">
        <hasUsageDomain rdf:resource="https://ontology.lotusim.org/naval-maritime#CivilUse"/>
    </owl:NamedIndividual>
    


    <!-- https://ontology.lotusim.org/naval-maritime#Wave -->


    <owl:NamedIndividual rdf:about="https://ontology.lotusim.org/naval-maritime#Wave">
        <hasUsageDomain rdf:resource="https://ontology.lotusim.org/naval-maritime#CivilUse"/>
    </owl:NamedIndividual>
    


    <!-- https://ontology.lotusim.org/naval-maritime#WaypointNavigationCapability -->


    <owl:NamedIndividual rdf:about="https://ontology.lotusim.org/naval-maritime#WaypointNavigationCapability">
        <hasUsageDomain rdf:resource="https://ontology.lotusim.org/naval-maritime#CivilUse"/>
    </owl:NamedIndividual>
    


