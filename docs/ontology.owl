    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotations
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#AIAccelerator">
        <rdfs:comment xml:lang="fr">Accélérateur dédié à l&apos;inférence IA embarquée.</rdfs:comment>
        <rdfs:label xml:lang="en">AI accelerator</rdfs:label>
        <rdfs:label xml:lang="fr">Accélérateur IA</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#AISTransceiver">
        <rdfs:comment xml:lang="fr">Émetteur-récepteur AIS : diffusion coopérative d&apos;identité et de cinématique. À la fois équipement de communication et senseur de la situation de surface.</rdfs:comment>
        <rdfs:label xml:lang="en">AIS transceiver</rdfs:label>
        <rdfs:label xml:lang="fr">Émetteur-récepteur AIS</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#AcousticCommunication">
        <rdfs:comment xml:lang="fr">Communication acoustique sous-marine : faible débit, latence élevée — la contrainte structurante des opérations multi-engins immergés.</rdfs:comment>
        <rdfs:label xml:lang="en">Acoustic communication</rdfs:label>
        <rdfs:label xml:lang="fr">Communication acoustique</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#AcousticModem">
        <rdfs:comment xml:lang="fr">Modem acoustique : seul lien sans fil praticable sous l&apos;eau. Débit faible, latence élevée, portée limitée — la contrainte qui structure les opérations sous-marines multi-engins.</rdfs:comment>
        <rdfs:label xml:lang="en">Acoustic modem</rdfs:label>
        <rdfs:label xml:lang="fr">Modem acoustique</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#AcousticPerception">
        <rdfs:comment xml:lang="fr">Perception par voie acoustique — le canal dominant sous l&apos;eau.</rdfs:comment>
        <rdfs:label xml:lang="en">Acoustic perception</rdfs:label>
        <rdfs:label xml:lang="fr">Perception acoustique</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#AcousticSensor">
        <rdfs:comment xml:lang="fr">Senseur exploitant la propagation acoustique — le canal privilégié sous l&apos;eau, où les ondes radio et optiques portent peu.</rdfs:comment>
        <rdfs:label xml:lang="en">Acoustic sensor</rdfs:label>
        <rdfs:label xml:lang="fr">Senseur acoustique</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#ActiveSonar">
        <rdfs:comment xml:lang="fr">Sonar actif : émet et écoute l&apos;écho. Portée et zones d&apos;ombre gouvernées par le profil de célérité ; trahit sa présence en émettant.</rdfs:comment>
        <rdfs:label xml:lang="en">Active sonar</rdfs:label>
        <rdfs:label xml:lang="fr">Sonar actif</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Actuator">
        <rdfs:comment xml:lang="fr">Dispositif physique d&apos;action : modifie l&apos;état de sa plateforme, manipule un objet ou met en œuvre un équipement. Aligné sur sosa:Actuator.</rdfs:comment>
        <rdfs:label xml:lang="fr">Actionneur</rdfs:label>
        <rdfs:label xml:lang="en">Actuator</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#AirMobility">
        <rdfs:comment xml:lang="fr">Mobilité dans l&apos;atmosphère.</rdfs:comment>
        <rdfs:label xml:lang="en">Air mobility</rdfs:label>
        <rdfs:label xml:lang="fr">Mobilité aérienne</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#AirPlatform">
        <rdfs:comment xml:lang="fr">Plateforme évoluant dans l&apos;atmosphère (ou au-delà pour les satellites).</rdfs:comment>
        <rdfs:label xml:lang="en">Air platform</rdfs:label>
        <rdfs:label xml:lang="fr">Plateforme aérienne</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Aircraft">
        <rdfs:comment xml:lang="fr">Aéronef habité opérant en environnement maritime.</rdfs:comment>
        <rdfs:label xml:lang="en">Aircraft</rdfs:label>
        <rdfs:label xml:lang="fr">Aéronef</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#AircraftWreck">
        <rdfs:comment xml:lang="fr">Épave d&apos;aéronef immergée.</rdfs:comment>
        <rdfs:label xml:lang="en">Aircraft wreck</rdfs:label>
        <rdfs:label xml:lang="fr">Épave d&apos;aéronef</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Airspace">
        <rdfs:comment xml:lang="fr">Volume d&apos;espace aérien délimité.</rdfs:comment>
        <rdfs:label xml:lang="en">Airspace</rdfs:label>
        <rdfs:label xml:lang="fr">Espace aérien</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Altimeter">
        <rdfs:comment xml:lang="fr">Altimètre : hauteur au-dessus du fond (acoustique) ou de la surface.</rdfs:comment>
        <rdfs:label xml:lang="en">Altimeter</rdfs:label>
        <rdfs:label xml:lang="fr">Altimètre</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Anchor">
        <rdfs:comment xml:lang="fr">Ancre : objet de mouillage, posé ou croché au fond.</rdfs:comment>
        <rdfs:label xml:lang="en">Anchor</rdfs:label>
        <rdfs:label xml:lang="fr">Ancre</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#AquacultureFacility">
        <rdfs:comment xml:lang="fr">Installation aquacole (cages, filières). Obstacle de subsurface mal cartographié.</rdfs:comment>
        <rdfs:label xml:lang="en">Aquaculture facility</rdfs:label>
        <rdfs:label xml:lang="fr">Installation aquacole</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#ArtificialObject">
        <rdfs:comment xml:lang="fr">Objet passif d&apos;origine humaine : ne porte rien, n&apos;agit pas, est perçu ou subi.</rdfs:comment>
        <rdfs:label xml:lang="en">Artificial object</rdfs:label>
        <rdfs:label xml:lang="fr">Objet artificiel</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#AssessmentCapability">
        <rdfs:comment xml:lang="en">Capability to derive an operational assessment from available information.</rdfs:comment>
        <rdfs:label xml:lang="en">Assessment capability</rdfs:label>
        <rdfs:label xml:lang="fr">Capacité d&apos;évaluation</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Atmosphere">
        <rdfs:comment xml:lang="fr">Milieu gazeux au-dessus de la surface. Siège des phénomènes météorologiques et milieu de propagation des ondes radio et optiques.</rdfs:comment>
        <rdfs:label xml:lang="en">Atmosphere</rdfs:label>
        <rdfs:label xml:lang="fr">Atmosphère</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#AutonomousUnderwaterVehicle">
        <rdfs:comment xml:lang="fr">AUV : opère sans contrôle temps réel d&apos;un opérateur. Optimisé pour la collecte de données sur zone étendue.</rdfs:comment>
        <rdfs:label xml:lang="fr">AUV</rdfs:label>
        <rdfs:label xml:lang="en">Autonomous underwater vehicle</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#BallastSystem">
        <rdfs:comment xml:lang="fr">Système de ballast : modifie la flottabilité (immersion des sous-marins, propulsion des planeurs).</rdfs:comment>
        <rdfs:label xml:lang="en">Ballast system</rdfs:label>
        <rdfs:label xml:lang="fr">Système de ballast</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Balloon">
        <rdfs:comment xml:lang="fr">Ballon ou aérostat : plateforme aérienne à sustentation statique, longue endurance, faible manœuvrabilité.</rdfs:comment>
        <rdfs:label xml:lang="fr">Ballon</rdfs:label>
        <rdfs:label xml:lang="en">Balloon</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Battery">
        <rdfs:comment xml:lang="fr">Batterie : stockage électrochimique. Son niveau borne l&apos;endurance — première ressource abstraite en prédicat (« autonomie suffisante »).</rdfs:comment>
        <rdfs:label xml:lang="fr">Batterie</rdfs:label>
        <rdfs:label xml:lang="en">Battery</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Beacon">
        <rdfs:comment xml:lang="fr">Balise fixe d&apos;aide à la navigation.</rdfs:comment>
        <rdfs:label xml:lang="fr">Balise</rdfs:label>
        <rdfs:label xml:lang="en">Beacon</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Boat">
        <rdfs:comment xml:lang="fr">Embarcation de surface de taille modeste (pêche, plaisance, servitude).</rdfs:comment>
        <rdfs:label xml:lang="fr">Bateau</rdfs:label>
        <rdfs:label xml:lang="en">Boat</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Bomb">
        <rdfs:comment xml:lang="fr">Bombe non explosée immergée (héritage historique typique).</rdfs:comment>
        <rdfs:label xml:lang="en">Bomb</rdfs:label>
        <rdfs:label xml:lang="fr">Bombe</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#BottomMine">
        <rdfs:comment xml:lang="fr">Mine posée sur le fond. Détection par sonar imageur, signature dépendante de la nature du sédiment et de l&apos;ensouillement.</rdfs:comment>
        <rdfs:label xml:lang="en">Bottom mine</rdfs:label>
        <rdfs:label xml:lang="fr">Mine de fond</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Breakwater">
        <rdfs:comment xml:lang="fr">Brise-lames : ouvrage de protection contre la houle.</rdfs:comment>
        <rdfs:label xml:lang="en">Breakwater</rdfs:label>
        <rdfs:label xml:lang="fr">Brise-lames</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Buoy">
        <rdfs:comment xml:lang="fr">Bouée d&apos;aide à la navigation (flottante, mouillée).</rdfs:comment>
        <rdfs:label xml:lang="fr">Bouée</rdfs:label>
        <rdfs:label xml:lang="en">Buoy</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#CTDProbe">
        <rdfs:comment xml:lang="fr">Sonde CTD (conductivité, température, profondeur) : mesure les gradients dont dérive le profil de célérité du son.</rdfs:comment>
        <rdfs:label xml:lang="en">CTD probe</rdfs:label>
        <rdfs:label xml:lang="fr">Sonde CTD</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#CableSegment">
        <rdfs:comment xml:lang="fr">Segment de câble posé ou ensouillé (télécom, énergie). Cible typique d&apos;inspection par ROV/AUV.</rdfs:comment>
        <rdfs:label xml:lang="en">Cable segment</rdfs:label>
        <rdfs:label xml:lang="fr">Segment de câble</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Camera">
        <rdfs:comment xml:lang="fr">Caméra visible : identification à courte portée, inspection.</rdfs:comment>
        <rdfs:label xml:lang="en">Camera</rdfs:label>
        <rdfs:label xml:lang="fr">Caméra</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Chain">
        <rdfs:comment xml:lang="fr">Chaîne : élément de liaison ou de mouillage, souvent partiellement ensouillé.</rdfs:comment>
        <rdfs:label xml:lang="en">Chain</rdfs:label>
        <rdfs:label xml:lang="fr">Chaîne</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Channel">
        <rdfs:comment xml:lang="fr">Chenal : passage navigable délimité, naturel ou dragué.</rdfs:comment>
        <rdfs:label xml:lang="en">Channel</rdfs:label>
        <rdfs:label xml:lang="fr">Chenal</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#ChannelMarker">
        <rdfs:comment xml:lang="fr">Marque de chenal : matérialise les limites navigables.</rdfs:comment>
        <rdfs:label xml:lang="en">Channel marker</rdfs:label>
        <rdfs:label xml:lang="fr">Marque de chenal</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#ChemicalHazardObject">
        <rdfs:comment xml:lang="fr">Objet à risque chimique (fût, cargaison dangereuse immergée).</rdfs:comment>
        <rdfs:label xml:lang="en">Chemical hazard object</rdfs:label>
        <rdfs:label xml:lang="fr">Objet à risque chimique</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#ClassificationCapability">
        <rdfs:comment xml:lang="fr">Capacité à attribuer un type physique d&apos;après des caractéristiques mesurées (dimensions, signature). Exclut l&apos;identification d&apos;allégeance — interprétation opérationnelle hors périmètre de l&apos;ontologie.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de classification</rdfs:label>
        <rdfs:label xml:lang="en">Classification capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#CoastalArea">
        <rdfs:comment xml:lang="fr">Zone côtière : interface terre-mer, faibles profondeurs.</rdfs:comment>
        <rdfs:label xml:lang="en">Coastal area</rdfs:label>
        <rdfs:label xml:lang="fr">Zone côtière</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#CoastalInfrastructure">
        <rdfs:comment xml:lang="fr">Infrastructure côtière (ouvrages portuaires et de protection).</rdfs:comment>
        <rdfs:label xml:lang="en">Coastal infrastructure</rdfs:label>
        <rdfs:label xml:lang="fr">Infrastructure côtière</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#CoastalStation">
        <rdfs:comment xml:lang="fr">Station côtière : plateforme fixe à terre (surveillance, communication).</rdfs:comment>
        <rdfs:label xml:lang="en">Coastal station</rdfs:label>
        <rdfs:label xml:lang="fr">Station côtière</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#CommunicationCapability">
        <rdfs:comment xml:lang="fr">Capacité à échanger de l&apos;information avec d&apos;autres systèmes.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de communication</rdfs:label>
        <rdfs:label xml:lang="en">Communication capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#CommunicationDevice">
        <rdfs:comment xml:lang="fr">Équipement de communication : transmet de l&apos;information entre plateformes ou vers l&apos;infrastructure.</rdfs:comment>
        <rdfs:label xml:lang="en">Communication device</rdfs:label>
        <rdfs:label xml:lang="fr">Équipement de communication</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#CommunicationLink">
        <rdfs:comment xml:lang="en">Technical communication connection between two or more communicating entities.</rdfs:comment>
        <rdfs:label xml:lang="en">Communication link</rdfs:label>
        <rdfs:label xml:lang="fr">Liaison de communication</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#CommunicationNetwork">
        <rdfs:comment xml:lang="en">Set of communication entities and links providing connectivity.</rdfs:comment>
        <rdfs:label xml:lang="en">Communication network</rdfs:label>
        <rdfs:label xml:lang="fr">Réseau de communication</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Compass">
        <rdfs:comment xml:lang="fr">Compas : cap magnétique ou gyroscopique.</rdfs:comment>
        <rdfs:label xml:lang="fr">Compas</rdfs:label>
        <rdfs:label xml:lang="en">Compass</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#ComputingDevice">
        <rdfs:comment xml:lang="fr">Équipement de calcul embarqué.</rdfs:comment>
        <rdfs:label xml:lang="en">Computing device</rdfs:label>
        <rdfs:label xml:lang="fr">Équipement de calcul</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Configuration">
        <rdfs:comment xml:lang="fr">Organisation physique effective des composants d&apos;un système.</rdfs:comment>
        <rdfs:label xml:lang="en">Configuration</rdfs:label>
        <rdfs:label xml:lang="fr">Configuration</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Container">
        <rdfs:comment xml:lang="fr">Conteneur, éventuellement perdu à la mer : obstacle flottant ou posé, écho sonar caractéristique.</rdfs:comment>
        <rdfs:label xml:lang="en">Container</rdfs:label>
        <rdfs:label xml:lang="fr">Conteneur</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#ControlSurface">
        <rdfs:comment xml:lang="fr">Gouverne : surface de contrôle d&apos;attitude et de cap (safran, barres de plongée, ailerons).</rdfs:comment>
        <rdfs:label xml:lang="en">Control surface</rdfs:label>
        <rdfs:label xml:lang="fr">Gouverne</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#CoordinationCapability">
        <rdfs:comment xml:lang="en">Capability to synchronize actions or relative states among multiple actors.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de coordination</rdfs:label>
        <rdfs:label xml:lang="en">Coordination capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Corridor">
        <rdfs:comment xml:lang="en">Bounded spatial passage through which movement or an operation may be organized.</rdfs:comment>
        <rdfs:label xml:lang="en">Corridor</rdfs:label>
        <rdfs:label xml:lang="fr">Corridor</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Current">
        <rdfs:comment xml:lang="fr">Courant marin : déplace et fait dériver les plateformes, en particulier les plus lentes (AUV, glider, ROV) ; contraint la navigation et la tenue de trajectoire.</rdfs:comment>
        <rdfs:label xml:lang="fr">Courant</rdfs:label>
        <rdfs:label xml:lang="en">Current</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#DataProcessingCapability">
        <rdfs:comment xml:lang="fr">Capacité de traitement de données à bord.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de traitement de données</rdfs:label>
        <rdfs:label xml:lang="en">Data processing capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#DataStorage">
        <rdfs:comment xml:lang="fr">Support de stockage de données (enregistrement des mesures en mission).</rdfs:comment>
        <rdfs:label xml:lang="en">Data storage</rdfs:label>
        <rdfs:label xml:lang="fr">Stockage de données</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#DataStorageCapability">
        <rdfs:comment xml:lang="fr">Capacité de stockage de données à bord.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de stockage de données</rdfs:label>
        <rdfs:label xml:lang="en">Data storage capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Debris">
        <rdfs:comment xml:lang="fr">Débris ou objet perdu, posé ou dérivant. Générateur de fausses alarmes en détection.</rdfs:comment>
        <rdfs:label xml:lang="en">Debris</rdfs:label>
        <rdfs:label xml:lang="fr">Débris</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Decoy">
        <rdfs:comment xml:lang="en">Physical object designed to create a deceptive signature or apparent target.</rdfs:comment>
        <rdfs:label xml:lang="en">Decoy</rdfs:label>
        <rdfs:label xml:lang="fr">Leurre</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#DemolitionCharge">
        <rdfs:comment xml:lang="fr">Charge de démolition : explosif mis en œuvre pour neutraliser un engin ou détruire une structure.</rdfs:comment>
        <rdfs:label xml:lang="fr">Charge de démolition</rdfs:label>
        <rdfs:label xml:lang="en">Demolition charge</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#DeploymentCapability">
        <rdfs:comment xml:lang="fr">Capacité à mettre à l&apos;eau un engin ou un équipement.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de mise en œuvre</rdfs:label>
        <rdfs:label xml:lang="en">Deployment capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#DeploymentSystem">
        <rdfs:comment xml:lang="fr">Système de mise à l&apos;eau (LARS, portique, rampe) : déploie un engin ou un équipement depuis la plateforme porteuse.</rdfs:comment>
        <rdfs:label xml:lang="en">Deployment system</rdfs:label>
        <rdfs:label xml:lang="fr">Système de mise en œuvre</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#DepthSensor">
        <rdfs:comment xml:lang="fr">Capteur de profondeur (pression).</rdfs:comment>
        <rdfs:label xml:lang="fr">Capteur de profondeur</rdfs:label>
        <rdfs:label xml:lang="en">Depth sensor</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#DetectionCapability">
        <rdfs:comment xml:lang="fr">Capacité à constater la présence d&apos;un objet ou d&apos;un signal au-dessus d&apos;un seuil (vue physique : un écho, un contact, une signature).</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de détection</rdfs:label>
        <rdfs:label xml:lang="en">Detection capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#DivingCapability">
        <rdfs:comment xml:lang="fr">Capacité à descendre en immersion (changer d&apos;immersion vers le bas).</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de plongée</rdfs:label>
        <rdfs:label xml:lang="en">Diving capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Dock">
        <rdfs:comment xml:lang="fr">Dock : bassin ou ouvrage d&apos;accueil des navires.</rdfs:comment>
        <rdfs:label xml:lang="en">Dock</rdfs:label>
        <rdfs:label xml:lang="fr">Dock</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#DockingCapability">
        <rdfs:comment xml:lang="fr">Capacité d&apos;accostage ou d&apos;amarrage à une structure (station de recharge, plateforme porteuse).</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité d&apos;accostage</rdfs:label>
        <rdfs:label xml:lang="en">Docking capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#DopplerVelocityLog">
        <rdfs:comment xml:lang="fr">Loch Doppler (DVL) : vitesse par rapport au fond par effet Doppler acoustique. Recale la dérive de la centrale inertielle.</rdfs:comment>
        <rdfs:label xml:lang="fr">DVL</rdfs:label>
        <rdfs:label xml:lang="en">Doppler velocity log</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#DriftingMine">
        <rdfs:comment xml:lang="fr">Mine dérivante, non fixée, portée par les courants.</rdfs:comment>
        <rdfs:label xml:lang="en">Drifting mine</rdfs:label>
        <rdfs:label xml:lang="fr">Mine dérivante</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#EchoSounder">
        <rdfs:comment xml:lang="fr">Sondeur : mesure la profondeur sous la quille.</rdfs:comment>
        <rdfs:label xml:lang="en">Echo sounder</rdfs:label>
        <rdfs:label xml:lang="fr">Sondeur</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#ElectronicWarfareCapability">
        <rdfs:comment xml:lang="en">Capability to sense, exploit, protect or apply effects in the electromagnetic environment.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de guerre électronique</rdfs:label>
        <rdfs:label xml:lang="en">Electronic warfare capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#EmbeddedComputer">
        <rdfs:comment xml:lang="fr">Ordinateur embarqué : calculateur généraliste de la plateforme.</rdfs:comment>
        <rdfs:label xml:lang="en">Embedded computer</rdfs:label>
        <rdfs:label xml:lang="fr">Ordinateur embarqué</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#EnergyDevice">
        <rdfs:comment xml:lang="fr">Équipement énergétique : produit, stocke ou distribue l&apos;énergie de la plateforme.</rdfs:comment>
        <rdfs:label xml:lang="en">Energy device</rdfs:label>
        <rdfs:label xml:lang="fr">Équipement énergétique</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#EnergySupplyCapability">
        <rdfs:comment xml:lang="fr">Capacité d&apos;alimentation énergétique des équipements portés.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité d&apos;alimentation énergétique</rdfs:label>
        <rdfs:label xml:lang="en">Energy supply capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#EngagementCapability">
        <rdfs:comment xml:lang="fr">Capacité à engager une cible désignée. Distincte de la capacité de neutralisation (NeutralizationCapability), qui vise la neutralisation d&apos;objets (p. ex. guerre des mines). L&apos;ontologie décrit la capacité physique, pas son backend d&apos;exécution : en première version LSGA, le résultat d&apos;un engagement est adjugé par la cellule blanche.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité d&apos;engagement</rdfs:label>
        <rdfs:label xml:lang="en">Engagement capability</rdfs:label>
        <manifestKey>engage.attack_target</manifestKey>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#EntityGroup">
        <rdfs:comment xml:lang="en">Aggregate of entities considered together for a stable structural purpose. Operational group roles remain in the Scenario Model.</rdfs:comment>
        <rdfs:label xml:lang="en">Entity group</rdfs:label>
        <rdfs:label xml:lang="fr">Groupe d&apos;entités</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#EnvironmentalFeature">
        <rdfs:comment xml:lang="fr">Caractéristique structurelle du milieu, quasi statique à l&apos;échelle d&apos;un scénario (thermocline, relief, glace).</rdfs:comment>
        <rdfs:label xml:lang="fr">Caractéristique environnementale</rdfs:label>
        <rdfs:label xml:lang="en">Environmental feature</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#EnvironmentalPerception">
        <rdfs:comment xml:lang="fr">Capacité à mesurer les propriétés du milieu (colonne d&apos;eau, météo-océano).</rdfs:comment>
        <rdfs:label xml:lang="en">Environmental perception</rdfs:label>
        <rdfs:label xml:lang="fr">Perception environnementale</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#EnvironmentalPhenomenon">
        <rdfs:comment xml:lang="fr">Phénomène dynamique du milieu exerçant un forçage sur les plateformes (courant, vague, vent, marée).</rdfs:comment>
        <rdfs:label xml:lang="en">Environmental phenomenon</rdfs:label>
        <rdfs:label xml:lang="fr">Phénomène environnemental</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#EnvironmentalSensor">
        <rdfs:comment xml:lang="fr">Senseur mesurant les propriétés du milieu (colonne d&apos;eau, météo-océano).</rdfs:comment>
        <rdfs:label xml:lang="en">Environmental sensor</rdfs:label>
        <rdfs:label xml:lang="fr">Senseur environnemental</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#EnvironmentalState">
        <rdfs:comment xml:lang="fr">État courant du milieu à un instant donné (conditions météo-océano en vigueur).</rdfs:comment>
        <rdfs:label xml:lang="en">Environmental state</rdfs:label>
        <rdfs:label xml:lang="fr">État environnemental</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Equipment">
        <rdfs:comment xml:lang="fr">Système physique porté par une plateforme : senseur, actionneur, communication, calcul, énergie, stockage. Ne se déplace pas par lui-même — c&apos;est le porteur qui bouge.</rdfs:comment>
        <rdfs:label xml:lang="en">Equipment</rdfs:label>
        <rdfs:label xml:lang="fr">Équipement</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#EquipmentWreck">
        <rdfs:comment xml:lang="fr">Épave d&apos;équipement (engin, instrument coulé).</rdfs:comment>
        <rdfs:label xml:lang="en">Equipment wreck</rdfs:label>
        <rdfs:label xml:lang="fr">Épave d&apos;équipement</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#ExplosiveObject">
        <rdfs:comment xml:lang="fr">Objet contenant une charge explosive. Couvre les usages militaires (mines, munitions) et civils (démolition sous-marine).</rdfs:comment>
        <rdfs:label xml:lang="en">Explosive object</rdfs:label>
        <rdfs:label xml:lang="fr">Objet explosif</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#FPGA">
        <rdfs:comment xml:lang="fr">Circuit logique programmable : traitement temps réel au plus près du senseur.</rdfs:comment>
        <rdfs:label xml:lang="en">FPGA</rdfs:label>
        <rdfs:label xml:lang="fr">FPGA</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#FastAttackCraft">
        <rdfs:comment xml:lang="fr">Petite embarcation rapide et manœuvrante, faiblement armée. Sa caractéristique physique déterminante est la vitesse ; son caractère menaçant relève d&apos;une relation de scénario (allégeance), hors de l&apos;ontologie.</rdfs:comment>
        <rdfs:label xml:lang="en">Fast attack craft</rdfs:label>
        <rdfs:label xml:lang="fr">Vedette rapide</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#FieldPerception">
        <rdfs:comment xml:lang="fr">Perception des champs (magnétique, électrique) : détection d&apos;anomalies causées par les masses métalliques.</rdfs:comment>
        <rdfs:label xml:lang="en">Field perception</rdfs:label>
        <rdfs:label xml:lang="fr">Perception de champ</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#FieldSensor">
        <rdfs:comment xml:lang="fr">Senseur de champ (magnétique, électrique). Détecte les perturbations locales du champ terrestre causées par les masses métalliques.</rdfs:comment>
        <rdfs:label xml:lang="en">Field sensor</rdfs:label>
        <rdfs:label xml:lang="fr">Senseur de champ</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#FixedPlatform">
        <rdfs:comment xml:lang="fr">Plateforme fixe : porteur immobile d&apos;équipements (station, bouée instrumentée).</rdfs:comment>
        <rdfs:label xml:lang="en">Fixed platform</rdfs:label>
        <rdfs:label xml:lang="fr">Plateforme fixe</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#FloatingMine">
        <rdfs:comment xml:lang="fr">Mine flottant en surface ou en subsurface immédiate.</rdfs:comment>
        <rdfs:label xml:lang="en">Floating mine</rdfs:label>
        <rdfs:label xml:lang="fr">Mine flottante</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#FuelCell">
        <rdfs:comment xml:lang="fr">Pile à combustible : source électrique de longue endurance, notamment pour la propulsion anaérobie.</rdfs:comment>
        <rdfs:label xml:lang="en">Fuel cell</rdfs:label>
        <rdfs:label xml:lang="fr">Pile à combustible</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#FuelTank">
        <rdfs:comment xml:lang="fr">Réservoir de carburant.</rdfs:comment>
        <rdfs:label xml:lang="en">Fuel tank</rdfs:label>
        <rdfs:label xml:lang="fr">Réservoir de carburant</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#GNSSReceiver">
        <rdfs:comment xml:lang="fr">Récepteur GNSS : positionnement par constellation satellitaire. Indisponible en immersion — le sous-marin remonte ou dérive à l&apos;estime.</rdfs:comment>
        <rdfs:label xml:lang="en">GNSS receiver</rdfs:label>
        <rdfs:label xml:lang="fr">Récepteur GNSS</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#GPU">
        <rdfs:comment xml:lang="fr">Processeur graphique : calcul parallèle embarqué (traitement d&apos;image, IA).</rdfs:comment>
        <rdfs:label xml:lang="en">GPU</rdfs:label>
        <rdfs:label xml:lang="fr">Processeur graphique</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Generator">
        <rdfs:comment xml:lang="fr">Générateur : production électrique à bord.</rdfs:comment>
        <rdfs:label xml:lang="en">Generator</rdfs:label>
        <rdfs:label xml:lang="fr">Générateur</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#GroundMobility">
        <rdfs:comment xml:lang="fr">Mobilité à terre.</rdfs:comment>
        <rdfs:label xml:lang="en">Ground mobility</rdfs:label>
        <rdfs:label xml:lang="fr">Mobilité terrestre</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#GroundPlatform">
        <rdfs:comment xml:lang="fr">Plateforme évoluant à terre.</rdfs:comment>
        <rdfs:label xml:lang="en">Ground platform</rdfs:label>
        <rdfs:label xml:lang="fr">Plateforme terrestre</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#GunSystem">
        <rdfs:comment xml:lang="fr">Artillerie navale : arme à tir tendu et cadence élevée, portée courte à moyenne. Effecteur d&apos;engagement de cibles proches (surface, air rapproché).</rdfs:comment>
        <rdfs:label xml:lang="en">Gun system</rdfs:label>
        <rdfs:label xml:lang="fr">Système d&apos;artillerie</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Halocline">
        <rdfs:comment xml:lang="fr">Couche de fort gradient de salinité. Peut générer des gradients de célérité sévères, notamment près de la surface.</rdfs:comment>
        <rdfs:label xml:lang="en">Halocline</rdfs:label>
        <rdfs:label xml:lang="fr">Halocline</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#HarbourArea">
        <rdfs:comment xml:lang="fr">Zone portuaire : eaux abritées et aménagées.</rdfs:comment>
        <rdfs:label xml:lang="en">Harbour area</rdfs:label>
        <rdfs:label xml:lang="fr">Zone portuaire</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#HazardousObject">
        <rdfs:comment xml:lang="fr">Objet présentant un danger intrinsèque (chimique, radioactif, explosif) indépendamment de toute intention.</rdfs:comment>
        <rdfs:label xml:lang="en">Hazardous object</rdfs:label>
        <rdfs:label xml:lang="fr">Objet dangereux</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#HealthMonitoringCapability">
        <rdfs:comment xml:lang="fr">Capacité de surveillance de l&apos;état de santé des systèmes embarqués.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de surveillance de santé</rdfs:label>
        <rdfs:label xml:lang="en">Health monitoring capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Helicopter">
        <rdfs:comment xml:lang="fr">Hélicoptère : aéronef à voilure tournante, capacité de vol stationnaire, opérable depuis une plateforme navale.</rdfs:comment>
        <rdfs:label xml:lang="en">Helicopter</rdfs:label>
        <rdfs:label xml:lang="fr">Hélicoptère</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#HoveringCapability">
        <rdfs:comment xml:lang="fr">Capacité de vol ou de tenue stationnaire dans le milieu.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de vol stationnaire</rdfs:label>
        <rdfs:label xml:lang="en">Hovering capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#IceFeature">
        <rdfs:comment xml:lang="fr">Formation de glace structurante du milieu (banquise, glace de mer). Contraint la navigation de surface et l&apos;accès à la surface pour les engins sous-marins.</rdfs:comment>
        <rdfs:label xml:lang="fr">Formation de glace</rdfs:label>
        <rdfs:label xml:lang="en">Ice feature</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#IceObject">
        <rdfs:comment xml:lang="fr">Objet de glace flottant ou dérivant (growler, floe). Danger de collision peu détectable au radar.</rdfs:comment>
        <rdfs:label xml:lang="en">Ice object</rdfs:label>
        <rdfs:label xml:lang="fr">Objet de glace</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#IdentificationCapability">
        <rdfs:comment xml:lang="en">Capability to establish an identity assessment for an observed entity.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité d&apos;identification</rdfs:label>
        <rdfs:label xml:lang="en">Identification capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#ImagingRadar">
        <rdfs:comment xml:lang="fr">Radar imageur ou à onde de surface haute fréquence (détection au-delà de l&apos;horizon).</rdfs:comment>
        <rdfs:label xml:lang="en">Imaging radar</rdfs:label>
        <rdfs:label xml:lang="fr">Radar imageur</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#ImagingSonar">
        <rdfs:comment xml:lang="fr">Sonar imageur (latéral, frontal) : produit une image acoustique du fond ou de la scène. Instrument central de la détection d&apos;objets posés.</rdfs:comment>
        <rdfs:label xml:lang="en">Imaging sonar</rdfs:label>
        <rdfs:label xml:lang="fr">Sonar imageur</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#IndustrialDebris">
        <rdfs:comment xml:lang="fr">Débris d&apos;origine industrielle (structures, équipements abandonnés).</rdfs:comment>
        <rdfs:label xml:lang="fr">Débris industriel</rdfs:label>
        <rdfs:label xml:lang="en">Industrial debris</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#InertialNavigationSystem">
        <rdfs:comment xml:lang="fr">Centrale inertielle (INS/IMU) : mesure attitude, cap et déplacement par inertie. Seul positionnement continu en immersion ; dérive avec le temps.</rdfs:comment>
        <rdfs:label xml:lang="fr">Centrale inertielle</rdfs:label>
        <rdfs:label xml:lang="en">Inertial navigation system</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#InfraredCamera">
        <rdfs:comment xml:lang="fr">Caméra infrarouge : détection par contraste thermique, utilisable de nuit ; inopérante sous l&apos;eau.</rdfs:comment>
        <rdfs:label xml:lang="fr">Caméra infrarouge</rdfs:label>
        <rdfs:label xml:lang="en">Infrared camera</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Infrastructure">
        <rdfs:comment xml:lang="fr">Système physique fixe et permanent, support d&apos;activités. Ne se déplace pas mais peut porter des équipements.</rdfs:comment>
        <rdfs:label xml:lang="en">Infrastructure</rdfs:label>
        <rdfs:label xml:lang="fr">Infrastructure</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#InspectionCapability">
        <rdfs:comment xml:lang="en">Capability to examine an object or infrastructure at the required level of detail.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité d&apos;inspection</rdfs:label>
        <rdfs:label xml:lang="en">Inspection capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#InstrumentedBuoy">
        <rdfs:comment xml:lang="fr">Bouée ou mouillage instrumenté : plateforme fixe de mesure.</rdfs:comment>
        <rdfs:label xml:lang="fr">Bouée instrumentée</rdfs:label>
        <rdfs:label xml:lang="en">Instrumented buoy</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#InteractionCapability">
        <rdfs:comment xml:lang="fr">Capacité à agir physiquement sur un objet du monde.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité d&apos;interaction</rdfs:label>
        <rdfs:label xml:lang="en">Interaction capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#InterdictionCapability">
        <rdfs:comment xml:lang="en">Capability to prevent, constrain, stop or control an entity, movement or activity.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité d&apos;interdiction</rdfs:label>
        <rdfs:label xml:lang="en">Interdiction capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#LaunchAndRecoveryInfrastructure">
        <rdfs:comment xml:lang="en">Infrastructure supporting launch, docking or recovery of platforms.</rdfs:comment>
        <rdfs:label xml:lang="fr">Infrastructure de mise à l&apos;eau et de récupération</rdfs:label>
        <rdfs:label xml:lang="en">Launch and recovery infrastructure</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Lidar">
        <rdfs:comment xml:lang="fr">Lidar : télémétrie laser. En version bathymétrique, pénètre les eaux claires peu profondes ; portée dégradée par la turbidité.</rdfs:comment>
        <rdfs:label xml:lang="en">Lidar</rdfs:label>
        <rdfs:label xml:lang="fr">Lidar</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Lighthouse">
        <rdfs:comment xml:lang="fr">Phare : amer lumineux majeur.</rdfs:comment>
        <rdfs:label xml:lang="en">Lighthouse</rdfs:label>
        <rdfs:label xml:lang="fr">Phare</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#LocalizationCapability">
        <rdfs:comment xml:lang="fr">Capacité à estimer la position d&apos;un objet ou la sienne propre.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de localisation</rdfs:label>
        <rdfs:label xml:lang="en">Localization capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#LogisticsCapability">
        <rdfs:comment xml:lang="en">Capability to resupply, transfer, refuel, recharge or otherwise sustain platforms and forces.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité logistique</rdfs:label>
        <rdfs:label xml:lang="en">Logistics capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#LostEquipment">
        <rdfs:comment xml:lang="fr">Équipement perdu à la mer (engin de pêche, instrument, charge).</rdfs:comment>
        <rdfs:label xml:lang="en">Lost equipment</rdfs:label>
        <rdfs:label xml:lang="fr">Équipement perdu</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Magnetometer">
        <rdfs:comment xml:lang="fr">Magnétomètre : détecte les anomalies magnétiques (masses ferreuses immergées, UXO, épaves).</rdfs:comment>
        <rdfs:label xml:lang="en">Magnetometer</rdfs:label>
        <rdfs:label xml:lang="fr">Magnétomètre</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#ManipulationCapability">
        <rdfs:comment xml:lang="fr">Capacité à saisir, déplacer ou prélever un objet (repose sur les effecteurs de manipulation).</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de manipulation</rdfs:label>
        <rdfs:label xml:lang="en">Manipulation capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Manipulator">
        <rdfs:comment xml:lang="fr">Bras manipulateur / pince : saisir, déplacer, prélever un objet.</rdfs:comment>
        <rdfs:label xml:lang="fr">Manipulateur</rdfs:label>
        <rdfs:label xml:lang="en">Manipulator</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#MannedSubmersible">
        <rdfs:comment xml:lang="fr">Submersible habité civil (recherche, intervention, tourisme).</rdfs:comment>
        <rdfs:label xml:lang="en">Manned submersible</rdfs:label>
        <rdfs:label xml:lang="fr">Submersible habité</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#MarineOrganism">
        <rdfs:comment xml:lang="fr">Organisme marin (faune, banc de poissons). Source de bruit et d&apos;échos biologiques (fausses alarmes acoustiques).</rdfs:comment>
        <rdfs:label xml:lang="en">Marine organism</rdfs:label>
        <rdfs:label xml:lang="fr">Organisme marin</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#MaritimeArea">
        <rdfs:comment xml:lang="fr">Zone maritime générique délimitée en surface.</rdfs:comment>
        <rdfs:label xml:lang="en">Maritime area</rdfs:label>
        <rdfs:label xml:lang="fr">Zone maritime</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#MaritimeCriticalInfrastructure">
        <rdfs:comment xml:lang="en">Maritime infrastructure whose loss or degradation has significant operational or societal consequences.</rdfs:comment>
        <rdfs:label xml:lang="fr">Infrastructure maritime critique</rdfs:label>
        <rdfs:label xml:lang="en">Maritime critical infrastructure</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#MaritimeEnvironmentEntity">
        <rdfs:comment xml:lang="fr">Racine des entités environnementales maritimes : caractéristiques (features) et phénomènes.</rdfs:comment>
        <rdfs:label xml:lang="fr">Entité environnementale maritime</rdfs:label>
        <rdfs:label xml:lang="en">Maritime environment entity</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#MaritimeInfrastructure">
        <rdfs:comment xml:lang="fr">Infrastructure liée au milieu maritime (côtière, offshore, sous-marine, de navigation).</rdfs:comment>
        <rdfs:label xml:lang="fr">Infrastructure maritime</rdfs:label>
        <rdfs:label xml:lang="en">Maritime infrastructure</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#MarkingCapability">
        <rdfs:comment xml:lang="fr">Capacité à déposer une marque sur ou près d&apos;un objet localisé.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de balisage</rdfs:label>
        <rdfs:label xml:lang="en">Marking capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#MarkingSystem">
        <rdfs:comment xml:lang="fr">Système de balisage d&apos;objets : dépose une marque sur ou près d&apos;un objet localisé (contexte typique : marquage d&apos;engins avant neutralisation).</rdfs:comment>
        <rdfs:label xml:lang="en">Marking system</rdfs:label>
        <rdfs:label xml:lang="fr">Système de balisage</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Materiel">
        <rdfs:comment xml:lang="en">Physical supplies, equipment or goods transported, transferred or consumed in support activities.</rdfs:comment>
        <rdfs:label xml:lang="en">Materiel</rdfs:label>
        <rdfs:label xml:lang="fr">Matériel</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#MerchantShip">
        <rdfs:comment xml:lang="fr">Navire de surface civil de transport (cargo, pétrolier, porte-conteneurs). Généralement non armé ; objet de protection ou de menace dans les scénarios d&apos;escorte.</rdfs:comment>
        <rdfs:label xml:lang="en">Merchant ship</rdfs:label>
        <rdfs:label xml:lang="fr">Navire de commerce</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#MeteorologicalSensor">
        <rdfs:comment xml:lang="fr">Capteur météorologique (vent, pression, température de l&apos;air).</rdfs:comment>
        <rdfs:label xml:lang="fr">Capteur météorologique</rdfs:label>
        <rdfs:label xml:lang="en">Meteorological sensor</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#MilitaryPayload">
        <rdfs:comment xml:lang="en">Payload specifically designed for a military operational purpose.</rdfs:comment>
        <rdfs:label xml:lang="fr">Charge utile militaire</rdfs:label>
        <rdfs:label xml:lang="en">Military payload</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#MissileSystem">
        <rdfs:comment xml:lang="fr">Système de missiles embarqués : effecteur d&apos;engagement de cibles à moyenne ou longue portée.</rdfs:comment>
        <rdfs:label xml:lang="en">Missile system</rdfs:label>
        <rdfs:label xml:lang="fr">Système de missiles</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#MobilityCapability">
        <rdfs:comment xml:lang="fr">Capacité à se déplacer dans un milieu.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de mobilité</rdfs:label>
        <rdfs:label xml:lang="en">Mobility capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#MooredMine">
        <rdfs:comment xml:lang="fr">Mine à orin : flottante entre deux eaux, reliée au fond par un câble. Détectable dans la colonne d&apos;eau.</rdfs:comment>
        <rdfs:label xml:lang="fr">Mine à orin</rdfs:label>
        <rdfs:label xml:lang="en">Moored mine</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#MooringElement">
        <rdfs:comment xml:lang="fr">Élément de ligne de mouillage (corps-mort, flotteur intermédiaire, ligne).</rdfs:comment>
        <rdfs:label xml:lang="en">Mooring element</rdfs:label>
        <rdfs:label xml:lang="fr">Élément de mouillage</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#MooringSystem">
        <rdfs:comment xml:lang="fr">Système de mouillage de navigation (coffre, ligne de mouillage). Distinct du mouillage de mines, sans équivalent dans cette version.</rdfs:comment>
        <rdfs:label xml:lang="en">Mooring system</rdfs:label>
        <rdfs:label xml:lang="fr">Système de mouillage</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#MultibeamSonar">
        <rdfs:comment xml:lang="fr">Sonar multifaisceaux : bathymétrie et imagerie de la colonne d&apos;eau par balayage. Outil hydrographique standard.</rdfs:comment>
        <rdfs:label xml:lang="en">Multibeam sonar</rdfs:label>
        <rdfs:label xml:lang="fr">Sonar multifaisceaux</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#NaturalObject">
        <rdfs:comment xml:lang="fr">Objet passif d&apos;origine naturelle présent dans le milieu.</rdfs:comment>
        <rdfs:label xml:lang="en">Natural object</rdfs:label>
        <rdfs:label xml:lang="fr">Objet naturel</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#NavalBase">
        <rdfs:comment xml:lang="en">Military infrastructure supporting naval command, logistics, maintenance, berthing and operations. It may contain a harbour but is not a subclass of Harbour.</rdfs:comment>
        <rdfs:label xml:lang="fr">Base navale</rdfs:label>
        <rdfs:label xml:lang="en">Naval base</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#NavalMine">
        <rdfs:comment xml:lang="fr">Mine navale : engin explosif déposé volontairement dans le milieu. Passive une fois posée.</rdfs:comment>
        <rdfs:label xml:lang="fr">Mine navale</rdfs:label>
        <rdfs:label xml:lang="en">Naval mine</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#NavigationCapability">
        <rdfs:comment xml:lang="fr">Capacité de conduite du déplacement : savoir où l&apos;on est et rejoindre où l&apos;on va.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de navigation</rdfs:label>
        <rdfs:label xml:lang="en">Navigation capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#NavigationInfrastructure">
        <rdfs:comment xml:lang="fr">Aide à la navigation passive : balise, bouée, marque, phare.</rdfs:comment>
        <rdfs:label xml:lang="fr">Infrastructure de navigation</rdfs:label>
        <rdfs:label xml:lang="en">Navigation infrastructure</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#NavigationRadar">
        <rdfs:comment xml:lang="fr">Radar de navigation : anticollision et situation de surface. Détection des petits objets dégradée par l&apos;état de mer.</rdfs:comment>
        <rdfs:label xml:lang="en">Navigation radar</rdfs:label>
        <rdfs:label xml:lang="fr">Radar de navigation</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#NavigationSensor">
        <rdfs:comment xml:lang="fr">Senseur de navigation : fournit position, cap, vitesse ou profondeur à la plateforme porteuse.</rdfs:comment>
        <rdfs:label xml:lang="en">Navigation sensor</rdfs:label>
        <rdfs:label xml:lang="fr">Senseur de navigation</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#NeutralizationCapability">
        <rdfs:comment xml:lang="fr">Capacité à rendre un engin inopérant par effet physique (charge de neutralisation, émetteur d&apos;influence). Distincte de l&apos;engagement d&apos;une cible (EngagementCapability).</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de neutralisation</rdfs:label>
        <rdfs:label xml:lang="en">Neutralization capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#NeutralizationSystem">
        <rdfs:comment xml:lang="fr">Système de neutralisation : met en œuvre l&apos;effet rendant un engin inopérant (charge, émetteur d&apos;influence).</rdfs:comment>
        <rdfs:label xml:lang="en">Neutralization system</rdfs:label>
        <rdfs:label xml:lang="fr">Système de neutralisation</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#ObstacleAvoidanceCapability">
        <rdfs:comment xml:lang="fr">Capacité d&apos;évitement d&apos;obstacles en cours de route.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité d&apos;évitement d&apos;obstacles</rdfs:label>
        <rdfs:label xml:lang="en">Obstacle avoidance capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#OceanographicSensor">
        <rdfs:comment xml:lang="fr">Capteur océanographique (propriétés de la colonne d&apos;eau).</rdfs:comment>
        <rdfs:label xml:lang="fr">Capteur océanographique</rdfs:label>
        <rdfs:label xml:lang="en">Oceanographic sensor</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#OffshoreInfrastructure">
        <rdfs:comment xml:lang="fr">Infrastructure en mer ouverte (plateforme, éolienne, aquaculture).</rdfs:comment>
        <rdfs:label xml:lang="fr">Infrastructure offshore</rdfs:label>
        <rdfs:label xml:lang="en">Offshore infrastructure</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#OffshoreMonitoringStation">
        <rdfs:comment xml:lang="fr">Station de surveillance offshore fixe.</rdfs:comment>
        <rdfs:label xml:lang="en">Offshore monitoring station</rdfs:label>
        <rdfs:label xml:lang="fr">Station de surveillance offshore</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#OffshorePlatform">
        <rdfs:comment xml:lang="fr">Plateforme offshore fixe ou flottante (énergie, industrie).</rdfs:comment>
        <rdfs:label xml:lang="en">Offshore platform</rdfs:label>
        <rdfs:label xml:lang="fr">Plateforme offshore</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#OpticalCommunication">
        <rdfs:comment xml:lang="fr">Communication optique sous-marine : très haut débit, très courte portée, eaux claires.</rdfs:comment>
        <rdfs:label xml:lang="fr">Communication optique</rdfs:label>
        <rdfs:label xml:lang="en">Optical communication</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#OpticalCommunicationDevice">
        <rdfs:comment xml:lang="fr">Équipement de communication optique : très haut débit sous-marin à très courte portée, en eaux claires.</rdfs:comment>
        <rdfs:label xml:lang="en">Optical communication device</rdfs:label>
        <rdfs:label xml:lang="fr">Équipement de communication optique</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#OpticalPerception">
        <rdfs:comment xml:lang="fr">Perception par voie optique, à courte portée sous l&apos;eau (turbidité).</rdfs:comment>
        <rdfs:label xml:lang="en">Optical perception</rdfs:label>
        <rdfs:label xml:lang="fr">Perception optique</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#OpticalSensor">
        <rdfs:comment xml:lang="fr">Senseur optique. Portée fortement dégradée par la turbidité de l&apos;eau ; usage sous-marin à courte distance seulement.</rdfs:comment>
        <rdfs:label xml:lang="en">Optical sensor</rdfs:label>
        <rdfs:label xml:lang="fr">Senseur optique</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#PassiveSonar">
        <rdfs:comment xml:lang="fr">Sonar passif / hydrophone : écoute sans émettre. En réseau, fournit une localisation spatiale (détection/classification de contacts).</rdfs:comment>
        <rdfs:label xml:lang="en">Passive sonar</rdfs:label>
        <rdfs:label xml:lang="fr">Sonar passif</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Payload">
        <rdfs:comment xml:lang="en">Equipment or material carried by a platform for an operational purpose.</rdfs:comment>
        <rdfs:label xml:lang="fr">Charge utile</rdfs:label>
        <rdfs:label xml:lang="en">Payload</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#PayloadHostingCapability">
        <rdfs:comment xml:lang="fr">Capacité d&apos;emport : accueillir, alimenter et interfacer une charge utile.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité d&apos;emport</rdfs:label>
        <rdfs:label xml:lang="en">Payload hosting capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#PerceptionCapability">
        <rdfs:comment xml:lang="fr">Capacité à percevoir le monde au travers de senseurs.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de perception</rdfs:label>
        <rdfs:label xml:lang="en">Perception capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Person">
        <rdfs:comment xml:lang="en">Human physical entity represented in a maritime scenario.</rdfs:comment>
        <rdfs:label xml:lang="en">Person</rdfs:label>
        <rdfs:label xml:lang="fr">Personne</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#PersonnelGroup">
        <rdfs:comment xml:lang="en">Collection of persons considered as one structural aggregate.</rdfs:comment>
        <rdfs:label xml:lang="fr">Groupe de personnel</rdfs:label>
        <rdfs:label xml:lang="en">Personnel group</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#PhysicalCapability">
        <rdfs:comment xml:lang="fr">Fonction qu&apos;un système physique est susceptible de fournir selon son type, sa configuration et son état.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité physique</rdfs:label>
        <rdfs:label xml:lang="en">Physical capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#PhysicalEntity">
        <rdfs:comment xml:lang="fr">Toute entité ayant une existence physique dans le monde simulé.</rdfs:comment>
        <rdfs:label xml:lang="fr">Entité physique</rdfs:label>
        <rdfs:label xml:lang="en">Physical entity</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#PhysicalMedium">
        <rdfs:comment xml:lang="fr">Milieu physique de propagation et d&apos;évolution (atmosphère, colonne d&apos;eau, fond). Détermine quels senseurs et quelles communications sont opérants.</rdfs:comment>
        <rdfs:label xml:lang="fr">Milieu physique</rdfs:label>
        <rdfs:label xml:lang="en">Physical medium</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#PhysicalObject">
        <rdfs:comment xml:lang="fr">Entité matérielle considérée principalement comme un objet, sans exigence de composition fonctionnelle.</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet physique</rdfs:label>
        <rdfs:label xml:lang="en">Physical object</rdfs:label>
        <skos:closeMatch rdf:resource="http://www.w3.org/ns/sosa/FeatureOfInterest"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#PhysicalProperty">
        <rdfs:comment xml:lang="fr">Caractéristique physique mesurable d&apos;une entité. Alignée sur sosa:ObservableProperty.</rdfs:comment>
        <rdfs:label xml:lang="en">Physical property</rdfs:label>
        <rdfs:label xml:lang="fr">Propriété physique</rdfs:label>
        <skos:closeMatch rdf:resource="http://www.w3.org/ns/sosa/ObservableProperty"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#PhysicalState">
        <rdfs:comment xml:lang="fr">État instantané d&apos;une entité physique.</rdfs:comment>
        <rdfs:label xml:lang="en">Physical state</rdfs:label>
        <rdfs:label xml:lang="fr">État physique</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#PhysicalSubstance">
        <rdfs:comment xml:lang="fr">Substance physique (matière sans individualité d&apos;objet).</rdfs:comment>
        <rdfs:label xml:lang="en">Physical substance</rdfs:label>
        <rdfs:label xml:lang="fr">Substance physique</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#PhysicalSystem">
        <rdfs:comment xml:lang="fr">Entité physique composée de parties organisées remplissant une ou plusieurs fonctions.</rdfs:comment>
        <rdfs:label xml:lang="en">Physical system</rdfs:label>
        <rdfs:label xml:lang="fr">Système physique</rdfs:label>
        <skos:closeMatch rdf:resource="http://www.w3.org/ns/ssn/System"/>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Pier">
        <rdfs:comment xml:lang="fr">Jetée : ouvrage avancé en mer, accostage et protection.</rdfs:comment>
        <rdfs:label xml:lang="fr">Jetée</rdfs:label>
        <rdfs:label xml:lang="en">Pier</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#PipeSegment">
        <rdfs:comment xml:lang="fr">Segment de conduite posé ou ensouillé. Cible typique d&apos;inspection.</rdfs:comment>
        <rdfs:label xml:lang="en">Pipe segment</rdfs:label>
        <rdfs:label xml:lang="fr">Segment de conduite</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Platform">
        <rdfs:comment xml:lang="fr">Système physique servant de porteur à des équipements.</rdfs:comment>
        <rdfs:label xml:lang="fr">Plateforme</rdfs:label>
        <rdfs:label xml:lang="en">Platform</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#PlatformGroup">
        <rdfs:comment xml:lang="en">Collection of platforms considered as one aggregate. Convoy, task group, swarm and escort group are scenario roles, not ontology subclasses.</rdfs:comment>
        <rdfs:label xml:lang="fr">Groupe de plateformes</rdfs:label>
        <rdfs:label xml:lang="en">Platform group</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#PortInfrastructure">
        <rdfs:comment xml:lang="fr">Infrastructure portuaire générale.</rdfs:comment>
        <rdfs:label xml:lang="fr">Infrastructure portuaire</rdfs:label>
        <rdfs:label xml:lang="en">Port infrastructure</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#PositionEstimationCapability">
        <rdfs:comment xml:lang="fr">Capacité d&apos;estimation de position propre par fusion de senseurs de navigation.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité d&apos;estimation de position</rdfs:label>
        <rdfs:label xml:lang="en">Position estimation capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#PropertyValue">
        <rdfs:comment xml:lang="fr">Valeur datée d&apos;une propriété pour une entité (patron de réification propriété-valeur).</rdfs:comment>
        <rdfs:label xml:lang="en">Property value</rdfs:label>
        <rdfs:label xml:lang="fr">Valeur de propriété</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#PropulsionSystem">
        <rdfs:comment xml:lang="fr">Système de propulsion principale ou d&apos;appoint (hélice, hydrojet, thrusters vectoriels des ROV/AUV, rotors).</rdfs:comment>
        <rdfs:label xml:lang="en">Propulsion system</rdfs:label>
        <rdfs:label xml:lang="fr">Système de propulsion</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#ProtectionCapability">
        <rdfs:comment xml:lang="en">Capability to preserve another entity, group, area, infrastructure or service against harmful effects.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de protection</rdfs:label>
        <rdfs:label xml:lang="en">Protection capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Pycnocline">
        <rdfs:comment xml:lang="fr">Couche de fort gradient de densité (combinaison des gradients de température et de salinité). Barrière physique au mélange vertical.</rdfs:comment>
        <rdfs:label xml:lang="en">Pycnocline</rdfs:label>
        <rdfs:label xml:lang="fr">Pycnocline</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Quay">
        <rdfs:comment xml:lang="fr">Quai : ouvrage d&apos;accostage à terre.</rdfs:comment>
        <rdfs:label xml:lang="fr">Quai</rdfs:label>
        <rdfs:label xml:lang="en">Quay</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#RadioCommunication">
        <rdfs:comment xml:lang="fr">Communication radio : surface et air uniquement.</rdfs:comment>
        <rdfs:label xml:lang="fr">Communication radio</rdfs:label>
        <rdfs:label xml:lang="en">Radio communication</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#RadioFrequencyPerception">
        <rdfs:comment xml:lang="fr">Perception radioélectrique, en surface et dans l&apos;air uniquement.</rdfs:comment>
        <rdfs:label xml:lang="fr">Perception radioélectrique</rdfs:label>
        <rdfs:label xml:lang="en">Radio-frequency perception</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#RadioFrequencySensor">
        <rdfs:comment xml:lang="fr">Senseur radioélectrique. Les ondes radio ne pénètrent pratiquement pas l&apos;eau de mer : usage limité à la surface et à l&apos;air.</rdfs:comment>
        <rdfs:label xml:lang="en">Radio-frequency sensor</rdfs:label>
        <rdfs:label xml:lang="fr">Senseur radioélectrique</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#RadioTransceiver">
        <rdfs:comment xml:lang="fr">Émetteur-récepteur radio : liaison de surface et aérienne. Inopérant sous l&apos;eau.</rdfs:comment>
        <rdfs:label xml:lang="en">Radio transceiver</rdfs:label>
        <rdfs:label xml:lang="fr">Émetteur-récepteur radio</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#RadioactiveObject">
        <rdfs:comment xml:lang="fr">Objet à risque radiologique immergé.</rdfs:comment>
        <rdfs:label xml:lang="fr">Objet radioactif</rdfs:label>
        <rdfs:label xml:lang="en">Radioactive object</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#RecoveryCapability">
        <rdfs:comment xml:lang="fr">Capacité à récupérer un engin ou un équipement. Opération sensible à l&apos;état de mer.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de récupération</rdfs:label>
        <rdfs:label xml:lang="en">Recovery capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#RecoverySystem">
        <rdfs:comment xml:lang="fr">Système de récupération : reprend à bord un engin ou un équipement. Opération sensible à l&apos;état de mer.</rdfs:comment>
        <rdfs:label xml:lang="en">Recovery system</rdfs:label>
        <rdfs:label xml:lang="fr">Système de récupération</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Reef">
        <rdfs:comment xml:lang="fr">Récif : haut-fond rocheux ou corallien. Danger pour la navigation, relief de masquage acoustique.</rdfs:comment>
        <rdfs:label xml:lang="en">Reef</rdfs:label>
        <rdfs:label xml:lang="fr">Récif</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#RelayCapability">
        <rdfs:comment xml:lang="en">Capability to relay communications between otherwise disconnected or range-limited entities.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de relais</rdfs:label>
        <rdfs:label xml:lang="en">Relay capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#RemotelyOperatedVehicle">
        <rdfs:comment xml:lang="fr">ROV : relié par ombilical, contrôlé en temps réel. Adapté aux interventions et manipulations délicates.</rdfs:comment>
        <rdfs:label xml:lang="fr">ROV</rdfs:label>
        <rdfs:label xml:lang="en">Remotely operated vehicle</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#RestrictedArea">
        <rdfs:comment xml:lang="fr">Zone d&apos;accès restreint ou réglementé, quelle qu&apos;en soit la raison (réglementaire, sécurité, environnementale).</rdfs:comment>
        <rdfs:label xml:lang="en">Restricted area</rdfs:label>
        <rdfs:label xml:lang="fr">Zone restreinte</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Rock">
        <rdfs:comment xml:lang="fr">Rocher isolé sur le fond ou affleurant. Écho ponctuel dur, confusable avec un objet artificiel.</rdfs:comment>
        <rdfs:label xml:lang="fr">Rocher</rdfs:label>
        <rdfs:label xml:lang="en">Rock</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Route">
        <rdfs:comment xml:lang="en">Ordered spatial path used to organize movement between locations.</rdfs:comment>
        <rdfs:label xml:lang="en">Route</rdfs:label>
        <rdfs:label xml:lang="fr">Route</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#RouteFollowingCapability">
        <rdfs:comment xml:lang="fr">Capacité de suivi d&apos;une route planifiée.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de suivi de route</rdfs:label>
        <rdfs:label xml:lang="en">Route-following capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SailingPlatform">
        <rdfs:comment xml:lang="fr">Plateforme à propulsion vélique. La navigation s&apos;y fait par rapport au vent (tirer des bords) — cas d&apos;école d&apos;une autonomie spécifique à la plateforme.</rdfs:comment>
        <rdfs:label xml:lang="fr">Plateforme à voile</rdfs:label>
        <rdfs:label xml:lang="en">Sailing platform</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SamplingCapability">
        <rdfs:comment xml:lang="fr">Capacité à prélever un échantillon du milieu ou du fond.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de prélèvement</rdfs:label>
        <rdfs:label xml:lang="en">Sampling capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SamplingSystem">
        <rdfs:comment xml:lang="fr">Système de prélèvement : échantillonne le milieu ou le fond.</rdfs:comment>
        <rdfs:label xml:lang="en">Sampling system</rdfs:label>
        <rdfs:label xml:lang="fr">Système de prélèvement</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SatelliteCommunication">
        <rdfs:comment xml:lang="fr">Communication satellite : longue portée, en surface ou émersion.</rdfs:comment>
        <rdfs:label xml:lang="fr">Communication satellite</rdfs:label>
        <rdfs:label xml:lang="en">Satellite communication</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SatellitePlatform">
        <rdfs:comment xml:lang="fr">Plateforme satellitaire (observation, communication, positionnement).</rdfs:comment>
        <rdfs:label xml:lang="fr">Plateforme satellitaire</rdfs:label>
        <rdfs:label xml:lang="en">Satellite platform</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SatelliteTerminal">
        <rdfs:comment xml:lang="fr">Terminal satellite : liaison longue portée, en surface ou émersion uniquement.</rdfs:comment>
        <rdfs:label xml:lang="en">Satellite terminal</rdfs:label>
        <rdfs:label xml:lang="fr">Terminal satellite</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Seabed">
        <rdfs:comment xml:lang="fr">Substrat au fond de l&apos;eau. Sa composition et sa texture (vase, sable, roche) sont déterminées par rétrodiffusion acoustique et gouvernent la réverbération et la détection d&apos;objets posés.</rdfs:comment>
        <rdfs:label xml:lang="fr">Fond marin</rdfs:label>
        <rdfs:label xml:lang="en">Seabed</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SeabedArea">
        <rdfs:comment xml:lang="fr">Zone délimitée du fond marin (emprise 2D sur le fond).</rdfs:comment>
        <rdfs:label xml:lang="en">Seabed area</rdfs:label>
        <rdfs:label xml:lang="fr">Zone de fond marin</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SeabedRelief">
        <rdfs:comment xml:lang="fr">Topographie du fond et profondeur. Crée masques et zones d&apos;ombre pour la détection.</rdfs:comment>
        <rdfs:label xml:lang="fr">Relief du fond</rdfs:label>
        <rdfs:label xml:lang="en">Seabed relief</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SedimentTransport">
        <rdfs:comment xml:lang="fr">Déplacement de sédiments par les courants. Modifie la turbidité, peut ensevelir progressivement les objets posés.</rdfs:comment>
        <rdfs:label xml:lang="en">Sediment transport</rdfs:label>
        <rdfs:label xml:lang="fr">Transport sédimentaire</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SelfMonitoringCapability">
        <rdfs:comment xml:lang="fr">Capacité d&apos;auto-surveillance de la plateforme (état interne, ressources).</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité d&apos;auto-surveillance</rdfs:label>
        <rdfs:label xml:lang="en">Self-monitoring capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Sensor">
        <rdfs:comment xml:lang="fr">Dispositif physique réalisant une observation d&apos;une propriété du monde. Aligné sur sosa:Sensor.</rdfs:comment>
        <rdfs:label xml:lang="fr">Senseur</rdfs:label>
        <rdfs:label xml:lang="en">Sensor</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Shell">
        <rdfs:comment xml:lang="fr">Obus non explosé immergé.</rdfs:comment>
        <rdfs:label xml:lang="fr">Obus</rdfs:label>
        <rdfs:label xml:lang="en">Shell</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Ship">
        <rdfs:comment xml:lang="fr">Navire : bâtiment de surface de taille significative. Classe générique — les spécialisations (combat, commerce, travaux) restent à introduire.</rdfs:comment>
        <rdfs:label xml:lang="fr">Navire</rdfs:label>
        <rdfs:label xml:lang="en">Ship</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#ShipDebris">
        <rdfs:comment xml:lang="fr">Débris provenant d&apos;un navire.</rdfs:comment>
        <rdfs:label xml:lang="fr">Débris de navire</rdfs:label>
        <rdfs:label xml:lang="en">Ship debris</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Shipwreck">
        <rdfs:comment xml:lang="fr">Épave de navire. Repère sonar fort, abri biologique, source de fausses alarmes en chasse aux mines.</rdfs:comment>
        <rdfs:label xml:lang="en">Shipwreck</rdfs:label>
        <rdfs:label xml:lang="fr">Épave de navire</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SolarPanel">
        <rdfs:comment xml:lang="fr">Panneau solaire : recharge des plateformes de surface longue endurance.</rdfs:comment>
        <rdfs:label xml:lang="fr">Panneau solaire</rdfs:label>
        <rdfs:label xml:lang="en">Solar panel</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SpatialRegion">
        <rdfs:comment xml:lang="fr">Emprise spatiale (le « où »). Support de la géométrie, alignée sur geo:Feature (GeoSPARQL). Vocabulaire des zones du schéma de scénario.</rdfs:comment>
        <rdfs:label xml:lang="fr">Région spatiale</rdfs:label>
        <rdfs:label xml:lang="en">Spatial region</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#StationKeepingCapability">
        <rdfs:comment xml:lang="fr">Capacité à maintenir une position fixe malgré les forçages dynamiques (courant, vent). Distincte du suivi de cible mobile (TargetFollowingCapability).</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de maintien en position</rdfs:label>
        <rdfs:label xml:lang="en">Station-keeping capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#StorageDevice">
        <rdfs:comment xml:lang="fr">Équipement de stockage embarqué.</rdfs:comment>
        <rdfs:label xml:lang="en">Storage device</rdfs:label>
        <rdfs:label xml:lang="fr">Équipement de stockage</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Stratification">
        <rdfs:comment xml:lang="fr">Organisation de la colonne d&apos;eau en couches de propriétés distinctes. Cadre d&apos;ensemble des clines (thermo-, halo-, pycnocline).</rdfs:comment>
        <rdfs:label xml:lang="en">Stratification</rdfs:label>
        <rdfs:label xml:lang="fr">Stratification</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Submarine">
        <rdfs:comment xml:lang="fr">Sous-marin habité, à vocation essentiellement militaire (le submersible civil est MannedSubmersible).</rdfs:comment>
        <rdfs:label xml:lang="fr">Sous-marin</rdfs:label>
        <rdfs:label xml:lang="en">Submarine</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SubmarineCable">
        <rdfs:comment xml:lang="fr">Câble sous-marin de télécommunication ou d&apos;énergie.</rdfs:comment>
        <rdfs:label xml:lang="fr">Câble sous-marin</rdfs:label>
        <rdfs:label xml:lang="en">Submarine cable</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SubseaInfrastructure">
        <rdfs:comment xml:lang="fr">Infrastructure posée sur le fond ou ensouillée (câbles, pipelines, têtes de puits). Cible typique d&apos;inspection.</rdfs:comment>
        <rdfs:label xml:lang="fr">Infrastructure sous-marine</rdfs:label>
        <rdfs:label xml:lang="en">Subsea infrastructure</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SubseaManifold">
        <rdfs:comment xml:lang="fr">Collecteur sous-marin (nœud de production pétrolière/gazière).</rdfs:comment>
        <rdfs:label xml:lang="fr">Collecteur sous-marin</rdfs:label>
        <rdfs:label xml:lang="en">Subsea manifold</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SubseaPipeline">
        <rdfs:comment xml:lang="fr">Pipeline sous-marin.</rdfs:comment>
        <rdfs:label xml:lang="fr">Pipeline sous-marin</rdfs:label>
        <rdfs:label xml:lang="en">Subsea pipeline</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SubseaStation">
        <rdfs:comment xml:lang="fr">Station sous-marine posée (observatoire, nœud de recharge ou de communication).</rdfs:comment>
        <rdfs:label xml:lang="fr">Station sous-marine</rdfs:label>
        <rdfs:label xml:lang="en">Subsea station</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SubseaWellhead">
        <rdfs:comment xml:lang="fr">Tête de puits sous-marine.</rdfs:comment>
        <rdfs:label xml:lang="en">Subsea wellhead</rdfs:label>
        <rdfs:label xml:lang="fr">Tête de puits sous-marine</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SupportCapability">
        <rdfs:comment xml:lang="fr">Capacité de soutien interne à la plateforme (énergie, calcul, stockage, emport).</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de soutien</rdfs:label>
        <rdfs:label xml:lang="en">Support capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SurfaceBuoy">
        <rdfs:comment xml:lang="fr">Bouée de surface considérée comme plateforme : porte des équipements.</rdfs:comment>
        <rdfs:label xml:lang="fr">Bouée de surface</rdfs:label>
        <rdfs:label xml:lang="en">Surface buoy</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SurfaceMobility">
        <rdfs:comment xml:lang="fr">Mobilité à la surface de l&apos;eau.</rdfs:comment>
        <rdfs:label xml:lang="fr">Mobilité de surface</rdfs:label>
        <rdfs:label xml:lang="en">Surface mobility</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SurfacePlatform">
        <rdfs:comment xml:lang="fr">Plateforme évoluant à la surface de l&apos;eau.</rdfs:comment>
        <rdfs:label xml:lang="fr">Plateforme de surface</rdfs:label>
        <rdfs:label xml:lang="en">Surface platform</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SurfacingCapability">
        <rdfs:comment xml:lang="fr">Capacité à remonter en surface. Conditionne l&apos;accès au GNSS et aux communications radio.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de remontée en surface</rdfs:label>
        <rdfs:label xml:lang="en">Surfacing capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SurveyCapability">
        <rdfs:comment xml:lang="en">Capability to systematically characterize an area, route, infrastructure or physical environment.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de levé</rdfs:label>
        <rdfs:label xml:lang="en">Survey capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SystemModel">
        <rdfs:comment xml:lang="fr">Modèle (type constructeur) d&apos;un système : porte les capacités potentielles, que la configuration et l&apos;état rendent — ou non — disponibles.</rdfs:comment>
        <rdfs:label xml:lang="fr">Modèle de système</rdfs:label>
        <rdfs:label xml:lang="en">System model</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#SystemState">
        <rdfs:comment xml:lang="fr">État courant d&apos;un système physique à un instant donné (statut opérationnel, ressources). Côté LSGA : fluents de l&apos;état initial du Problem HDDL, re-capturés au replan.</rdfs:comment>
        <rdfs:label xml:lang="en">System state</rdfs:label>
        <rdfs:label xml:lang="fr">État système</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#TargetFollowingCapability">
        <rdfs:comment xml:lang="fr">Capacité de guidage relatif à une référence mobile : poursuite d&apos;une cible, tenue de poste sur cible en mouvement. Distincte de StationKeepingCapability, qui vise le maintien d&apos;une position fixe. Usages civils : escorte, convoyage, essais en mer.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de suivi de cible mobile</rdfs:label>
        <rdfs:label xml:lang="en">Target-following capability</rdfs:label>
        <manifestKey>navigation.follow_target</manifestKey>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Thermocline">
        <rdfs:comment xml:lang="fr">Couche de fort gradient de température. Induit un gradient de célérité du son qui courbe les rais acoustiques et crée des zones d&apos;ombre sonar.</rdfs:comment>
        <rdfs:label xml:lang="en">Thermocline</rdfs:label>
        <rdfs:label xml:lang="fr">Thermocline</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#ThreatAssessmentCapability">
        <rdfs:comment xml:lang="en">Capability to assess whether an observed entity or activity poses an operational threat.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité d&apos;évaluation de menace</rdfs:label>
        <rdfs:label xml:lang="en">Threat assessment capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Tide">
        <rdfs:comment xml:lang="fr">Variation périodique du niveau et des courants d&apos;origine astronomique. Conditionne les fenêtres d&apos;accès aux zones peu profondes et aux ports.</rdfs:comment>
        <rdfs:label xml:lang="fr">Marée</rdfs:label>
        <rdfs:label xml:lang="en">Tide</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Torpedo">
        <rdfs:comment xml:lang="fr">Torpille, considérée ici comme munition présente dans le milieu (épave d&apos;arme, exercice perdu).</rdfs:comment>
        <rdfs:label xml:lang="en">Torpedo</rdfs:label>
        <rdfs:label xml:lang="fr">Torpille</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#TrackingCapability">
        <rdfs:comment xml:lang="en">Capability to maintain an estimate of an observed entity state over time.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de suivi</rdfs:label>
        <rdfs:label xml:lang="en">Tracking capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#TransportCapability">
        <rdfs:comment xml:lang="en">Capability to transport personnel, payload or materiel.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de transport</rdfs:label>
        <rdfs:label xml:lang="en">Transport capability</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#UncrewedAerialVehicle">
        <rdfs:comment xml:lang="fr">Drone aérien (UAV) : voilure fixe ou VTOL, opéré depuis la terre ou une plateforme navale.</rdfs:comment>
        <rdfs:label xml:lang="fr">Drone aérien</rdfs:label>
        <rdfs:label xml:lang="en">Uncrewed aerial vehicle</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#UncrewedSurfaceVehicle">
        <rdfs:comment xml:lang="fr">Drone de surface (USV) : plateforme d&apos;appui offrant stabilité de surface, relais de communication et endurance aux opérations sous-marines.</rdfs:comment>
        <rdfs:label xml:lang="fr">Drone de surface</rdfs:label>
        <rdfs:label xml:lang="en">Uncrewed surface vehicle</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#UncrewedUnderwaterVehicle">
        <rdfs:comment xml:lang="fr">Drone sous-marin (UUV) : véhicule sous-marin sans équipage, regroupant AUV, ROV et planeurs.</rdfs:comment>
        <rdfs:label xml:lang="fr">Drone sous-marin</rdfs:label>
        <rdfs:label xml:lang="en">Uncrewed underwater vehicle</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#UnderwaterGlider">
        <rdfs:comment xml:lang="fr">Planeur sous-marin : propulsion par variation de flottabilité, très longue endurance, faible vitesse.</rdfs:comment>
        <rdfs:label xml:lang="fr">Planeur sous-marin</rdfs:label>
        <rdfs:label xml:lang="en">Underwater glider</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#UnderwaterMobility">
        <rdfs:comment xml:lang="fr">Mobilité dans la colonne d&apos;eau.</rdfs:comment>
        <rdfs:label xml:lang="fr">Mobilité sous-marine</rdfs:label>
        <rdfs:label xml:lang="en">Underwater mobility</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#UnderwaterPlatform">
        <rdfs:comment xml:lang="fr">Plateforme évoluant dans la colonne d&apos;eau.</rdfs:comment>
        <rdfs:label xml:lang="fr">Plateforme sous-marine</rdfs:label>
        <rdfs:label xml:lang="en">Underwater platform</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#UnexplodedOrdnance">
        <rdfs:comment xml:lang="fr">Munition non explosée (UXO) immergée, détectable notamment par perturbation magnétique.</rdfs:comment>
        <rdfs:label xml:lang="fr">Munition non explosée</rdfs:label>
        <rdfs:label xml:lang="en">Unexploded ordnance</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#UnidentifiedDebris">
        <rdfs:comment xml:lang="fr">Débris dont l&apos;origine n&apos;est pas établie. Cas nominal en début de classification.</rdfs:comment>
        <rdfs:label xml:lang="fr">Débris non identifié</rdfs:label>
        <rdfs:label xml:lang="en">Unidentified debris</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#UsageDomain">
        <rdfs:comment xml:lang="fr">Domaine d&apos;usage d&apos;un concept au regard de la diffusabilité : civil (librement diffusable), dual-use, militaire (hors diffusion publique). Support du filtrage des exports.</rdfs:comment>
        <rdfs:label xml:lang="fr">Domaine d&apos;usage</rdfs:label>
        <rdfs:label xml:lang="en">Usage domain</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#VegetationMass">
        <rdfs:comment xml:lang="fr">Masse végétale (algues, herbiers). Masque visuel et acoustique des objets posés.</rdfs:comment>
        <rdfs:label xml:lang="fr">Masse végétale</rdfs:label>
        <rdfs:label xml:lang="en">Vegetation mass</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Warship">
        <rdfs:comment xml:lang="fr">Bâtiment de surface à vocation militaire (frégate, patrouilleur, chasseur de mines, bâtiment de soutien étatique). Porte typiquement senseurs de veille et effecteurs d&apos;armement.</rdfs:comment>
        <rdfs:label xml:lang="fr">Bâtiment de combat</rdfs:label>
        <rdfs:label xml:lang="en">Warship</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#WaterColumn">
        <rdfs:comment xml:lang="fr">Milieu liquide entre la surface et le fond. Milieu de propagation acoustique privilégié ; ses gradients (température, salinité) gouvernent les trajets sonores.</rdfs:comment>
        <rdfs:label xml:lang="fr">Colonne d&apos;eau</rdfs:label>
        <rdfs:label xml:lang="en">Water column</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#WaterVolume">
        <rdfs:comment xml:lang="fr">Volume d&apos;eau délimité en trois dimensions dans la colonne d&apos;eau.</rdfs:comment>
        <rdfs:label xml:lang="fr">Volume d&apos;eau</rdfs:label>
        <rdfs:label xml:lang="en">Water volume</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Wave">
        <rdfs:comment xml:lang="fr">Agitation de la surface (houle, vagues). Forçage mécanique sur les plateformes de surface et à l&apos;interface (mise à l&apos;eau, récupération) ; dégrade la détection radar de petits objets.</rdfs:comment>
        <rdfs:label xml:lang="fr">Vague</rdfs:label>
        <rdfs:label xml:lang="en">Wave</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#WaypointNavigationCapability">
        <rdfs:comment xml:lang="fr">Capacité à rejoindre un point ou une zone désignés par une suite de points de passage.</rdfs:comment>
        <rdfs:label xml:lang="fr">Capacité de navigation par points de passage</rdfs:label>
        <rdfs:label xml:lang="en">Waypoint navigation capability</rdfs:label>
        <manifestKey>navigation.goto</manifestKey>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#WeaponSystem">
        <rdfs:comment xml:lang="fr">Effecteur d&apos;armement porté par une plateforme : met en œuvre l&apos;engagement d&apos;une cible désignée. Porte la capacité d&apos;engagement (EngagementCapability). L&apos;ontologie décrit l&apos;effecteur physique ; le résultat d&apos;un engagement est adjugé côté exécution (cellule blanche) en première version LSGA.</rdfs:comment>
        <rdfs:label xml:lang="fr">Système d&apos;arme</rdfs:label>
        <rdfs:label xml:lang="en">Weapon system</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Wind">
        <rdfs:comment xml:lang="fr">Action mécanique du vent sur les plateformes de surface et aériennes : dérive, gîte, limites d&apos;emploi des drones.</rdfs:comment>
        <rdfs:label xml:lang="fr">Vent</rdfs:label>
        <rdfs:label xml:lang="en">Wind</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#WindTurbine">
        <rdfs:comment xml:lang="fr">Éolienne en mer, posée ou flottante. Obstacle et source de bruit acoustique rayonné.</rdfs:comment>
        <rdfs:label xml:lang="en">Wind turbine</rdfs:label>
        <rdfs:label xml:lang="fr">Éolienne</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#WiredCommunication">
        <rdfs:comment xml:lang="fr">Communication filaire (ombilical) : déterministe et haut débit, au prix de la liberté de mouvement.</rdfs:comment>
        <rdfs:label xml:lang="fr">Communication filaire</rdfs:label>
        <rdfs:label xml:lang="en">Wired communication</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#WiredCommunicationDevice">
        <rdfs:comment xml:lang="fr">Équipement de communication filaire (ombilical, câble) : lien déterministe et haut débit au prix de la liberté de mouvement.</rdfs:comment>
        <rdfs:label xml:lang="en">Wired communication device</rdfs:label>
        <rdfs:label xml:lang="fr">Équipement de communication filaire</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://ontology.lotusim.org/naval-maritime#Wreck">
        <rdfs:comment xml:lang="fr">Épave : vestige immergé d&apos;une plateforme ou d&apos;un équipement. Objet passif — une fois coulée, une plateforme ne porte plus et n&apos;agit plus.</rdfs:comment>
        <rdfs:label xml:lang="en">Wreck</rdfs:label>
        <rdfs:label xml:lang="fr">Épave</rdfs:label>
    </rdf:Description>
</rdf:RDF>



