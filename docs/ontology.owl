        <rdfs:range rdf:resource="https://ontology.lotusim.org/naval-maritime#EnvironmentalPhenomenon"/>
        <rdfs:label xml:lang="en">affected by phenomenon</rdfs:label>
        <rdfs:label xml:lang="fr">est affecté par le phénomène</rdfs:label>
    </owl:ObjectProperty>
    


