  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "Bâtiment de surface à vocation militaire (frégate, patrouilleur, chasseur de mines, bâtiment de soutien étatique). Porte typiquement senseurs de veille et effecteurs d'armement."
  } ],
