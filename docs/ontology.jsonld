  } ],
  "https://ontology.lotusim.org/naval-maritime#manifestKey" : [ {
    "@value" : "navigation.goto"
  } ]
}, {
  "@id" : "https://ontology.lotusim.org/naval-maritime#WeaponSystem",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "Effecteur d'armement porté par une plateforme : met en œuvre l'engagement d'une cible désignée. Porte la capacité d'engagement (EngagementCapability). L'ontologie décrit l'effecteur physique ; le résultat d'un engagement est adjugé côté exécution (cellule blanche) en première version LSGA."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Système d'arme"
  }, {
    "@language" : "en",
    "@value" : "Weapon system"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontology.lotusim.org/naval-maritime#Actuator"
  } ],
  "https://ontology.lotusim.org/naval-maritime#enablesCapability" : [ {
    "@id" : "https://ontology.lotusim.org/naval-maritime#EngagementCapability"
  } ],
  "https://ontology.lotusim.org/naval-maritime#hasUsageDomain" : [ {
    "@id" : "https://ontology.lotusim.org/naval-maritime#MilitaryUse"
  } ]
}, {
  "@id" : "https://ontology.lotusim.org/naval-maritime#Wind",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "Action mécanique du vent sur les plateformes de surface et aériennes : dérive, gîte, limites d'emploi des drones."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Vent"
  }, {
    "@language" : "en",
    "@value" : "Wind"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
