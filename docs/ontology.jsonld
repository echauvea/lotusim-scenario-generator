}, {
  "@id" : "https://ontology.lotusim.org/naval-maritime#EngagementCapability",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "Capacité à engager une cible désignée. Distincte de la capacité de neutralisation (NeutralizationCapability), qui vise la neutralisation d'objets (p. ex. guerre des mines). L'ontologie décrit la capacité physique, pas son backend d'exécution : en première version LSGA, le résultat d'un engagement est adjugé par la cellule blanche."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Capacité d'engagement"
  }, {
    "@language" : "en",
    "@value" : "Engagement capability"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontology.lotusim.org/naval-maritime#InteractionCapability"
  } ],
  "https://ontology.lotusim.org/naval-maritime#hasUsageDomain" : [ {
    "@id" : "https://ontology.lotusim.org/naval-maritime#MilitaryUse"
  } ],
  "https://ontology.lotusim.org/naval-maritime#manifestKey" : [ {
    "@value" : "engage.attack_target"
  } ]
}, {
