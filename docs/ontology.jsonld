  } ]
}, {
  "@id" : "https://ontology.lotusim.org/naval-maritime#Wave",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "Agitation de la surface (houle, vagues). Forçage mécanique sur les plateformes de surface et à l'interface (mise à l'eau, récupération) ; dégrade la détection radar de petits objets."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Vague"
  }, {
    "@language" : "en",
    "@value" : "Wave"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
