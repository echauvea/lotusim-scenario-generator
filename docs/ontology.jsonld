}, {
  "@id" : "https://ontology.lotusim.org/naval-maritime",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/creator" : [ {
    "@value" : "Estelle Chauveau (Naval Group, PO LOTUSim)"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "Physical-world ontology for LOTUSim covering systems, platforms, equipment, physical objects, infrastructure, maritime environment, states, configurations, properties and physical capabilities."
  } ],
  "http://purl.org/dc/terms/modified" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-07-12"
  } ],
  "http://purl.org/dc/terms/publisher" : [ {
    "@value" : "Naval Group"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@language" : "en",
    "@value" : "LOTUSim Naval Maritime Ontology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "Ontologie de référence décrivant le monde naval physique simulable à un instant donné. Elle exclut les missions, objectifs, tâches, rôles opérationnels, observations, événements, doctrine et planification."
  }, {
    "@language" : "fr",
    "@value" : "Vocabulaire normatif de LOTUSim : les types du profil HDDL, le vocabulaire du schéma de scénario (agents, zones) et les familles des manifestes de capacités (nmo:manifestKey) en dérivent. Chaque classe porte une annotation de diffusabilité (nmo:hasUsageDomain : civil / dual-use / militaire) conditionnant sa présence dans les exports publics."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "LOTUSim Naval Maritime Ontology"
  }, {
    "@language" : "fr",
    "@value" : "Ontologie navale maritime LOTUSim"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "1.1.0-draft"
  } ]
}, {
  "@id" : "https://ontology.lotusim.org/naval-maritime#AIAccelerator",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "Accélérateur dédié à l'inférence IA embarquée."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "AI accelerator"
  }, {
    "@language" : "fr",
    "@value" : "Accélérateur IA"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontology.lotusim.org/naval-maritime#ComputingDevice"
  } ],
  "https://ontology.lotusim.org/naval-maritime#hasUsageDomain" : [ {
    "@id" : "https://ontology.lotusim.org/naval-maritime#CivilUse"
  } ]
}, {
  "@id" : "https://ontology.lotusim.org/naval-maritime#AISTransceiver",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "Émetteur-récepteur AIS : diffusion coopérative d'identité et de cinématique. À la fois équipement de communication et senseur de la situation de surface."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "AIS transceiver"
  }, {
    "@language" : "fr",
    "@value" : "Émetteur-récepteur AIS"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontology.lotusim.org/naval-maritime#CommunicationDevice"
  }, {
    "@id" : "https://ontology.lotusim.org/naval-maritime#Sensor"
  } ],
  "https://ontology.lotusim.org/naval-maritime#hasUsageDomain" : [ {
    "@id" : "https://ontology.lotusim.org/naval-maritime#CivilUse"
  } ]
}, {
  "@id" : "https://ontology.lotusim.org/naval-maritime#AcousticCommunication",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "Communication acoustique sous-marine : faible débit, latence élevée — la contrainte structurante des opérations multi-engins immergés."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Acoustic communication"
  }, {
    "@language" : "fr",
    "@value" : "Communication acoustique"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontology.lotusim.org/naval-maritime#CommunicationCapability"
  } ],
  "https://ontology.lotusim.org/naval-maritime#hasUsageDomain" : [ {
    "@id" : "https://ontology.lotusim.org/naval-maritime#DualUse"
  } ]
}, {
  "@id" : "https://ontology.lotusim.org/naval-maritime#AcousticModem",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "Modem acoustique : seul lien sans fil praticable sous l'eau. Débit faible, latence élevée, portée limitée — la contrainte qui structure les opérations sous-marines multi-engins."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Acoustic modem"
  }, {
    "@language" : "fr",
    "@value" : "Modem acoustique"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontology.lotusim.org/naval-maritime#CommunicationDevice"
  } ],
  "https://ontology.lotusim.org/naval-maritime#hasUsageDomain" : [ {
    "@id" : "https://ontology.lotusim.org/naval-maritime#DualUse"
  } ]
}, {
  "@id" : "https://ontology.lotusim.org/naval-maritime#AcousticPerception",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "Perception par voie acoustique — le canal dominant sous l'eau."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Acoustic perception"
  }, {
    "@language" : "fr",
    "@value" : "Perception acoustique"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontology.lotusim.org/naval-maritime#PerceptionCapability"
  } ],
  "https://ontology.lotusim.org/naval-maritime#hasUsageDomain" : [ {
    "@id" : "https://ontology.lotusim.org/naval-maritime#DualUse"
  } ]
}, {
  "@id" : "https://ontology.lotusim.org/naval-maritime#AcousticSensor",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "Senseur exploitant la propagation acoustique — le canal privilégié sous l'eau, où les ondes radio et optiques portent peu."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Acoustic sensor"
  }, {
    "@language" : "fr",
    "@value" : "Senseur acoustique"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontology.lotusim.org/naval-maritime#Sensor"
  } ],
  "https://ontology.lotusim.org/naval-maritime#hasUsageDomain" : [ {
    "@id" : "https://ontology.lotusim.org/naval-maritime#DualUse"
  } ]
}, {
  "@id" : "https://ontology.lotusim.org/naval-maritime#ActiveSonar",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "Sonar actif : émet et écoute l'écho. Portée et zones d'ombre gouvernées par le profil de célérité ; trahit sa présence en émettant."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Active sonar"
  }, {
    "@language" : "fr",
    "@value" : "Sonar actif"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://ontology.lotusim.org/naval-maritime#AcousticSensor"
  } ],
  "https://ontology.lotusim.org/naval-maritime#hasUsageDomain" : [ {
    "@id" : "https://ontology.lotusim.org/naval-maritime#DualUse"
  } ]
}, {
  "@id" : "https://ontology.lotusim.org/naval-maritime#Actuator",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fr",
    "@value" : "Dispositif physique d'action : modifie l'état de sa plateforme, manipule un objet ou met en œuvre un équipement. Aligné sur sosa:Actuator."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Actionneur"
  }, {
    "@language" : "en",
    "@value" : "Actuator"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/sosa/Actuator"
  }, {
