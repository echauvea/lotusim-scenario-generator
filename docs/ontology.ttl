       :hasUsageDomain :CivilUse .


#################################################################
#    Annotations
#################################################################

:AIAccelerator rdfs:comment "Accélérateur dédié à l'inférence IA embarquée."@fr ;
               rdfs:label "AI accelerator"@en ,
                          "Accélérateur IA"@fr .


:AISTransceiver rdfs:comment "Émetteur-récepteur AIS : diffusion coopérative d'identité et de cinématique. À la fois équipement de communication et senseur de la situation de surface."@fr ;
                rdfs:label "AIS transceiver"@en ,
                           "Émetteur-récepteur AIS"@fr .


:AcousticCommunication rdfs:comment "Communication acoustique sous-marine : faible débit, latence élevée — la contrainte structurante des opérations multi-engins immergés."@fr ;
                       rdfs:label "Acoustic communication"@en ,
                                  "Communication acoustique"@fr .


:AcousticModem rdfs:comment "Modem acoustique : seul lien sans fil praticable sous l'eau. Débit faible, latence élevée, portée limitée — la contrainte qui structure les opérations sous-marines multi-engins."@fr ;
               rdfs:label "Acoustic modem"@en ,
                          "Modem acoustique"@fr .


:AcousticPerception rdfs:comment "Perception par voie acoustique — le canal dominant sous l'eau."@fr ;
                    rdfs:label "Acoustic perception"@en ,
                               "Perception acoustique"@fr .


:AcousticSensor rdfs:comment "Senseur exploitant la propagation acoustique — le canal privilégié sous l'eau, où les ondes radio et optiques portent peu."@fr ;
                rdfs:label "Acoustic sensor"@en ,
                           "Senseur acoustique"@fr .


:ActiveSonar rdfs:comment "Sonar actif : émet et écoute l'écho. Portée et zones d'ombre gouvernées par le profil de célérité ; trahit sa présence en émettant."@fr ;
             rdfs:label "Active sonar"@en ,
                        "Sonar actif"@fr .


:Actuator rdfs:comment "Dispositif physique d'action : modifie l'état de sa plateforme, manipule un objet ou met en œuvre un équipement. Aligné sur sosa:Actuator."@fr ;
          rdfs:label "Actionneur"@fr ,
                     "Actuator"@en .


:AirMobility rdfs:comment "Mobilité dans l'atmosphère."@fr ;
             rdfs:label "Air mobility"@en ,
                        "Mobilité aérienne"@fr .


:AirPlatform rdfs:comment "Plateforme évoluant dans l'atmosphère (ou au-delà pour les satellites)."@fr ;
             rdfs:label "Air platform"@en ,
                        "Plateforme aérienne"@fr .


:Aircraft rdfs:comment "Aéronef habité opérant en environnement maritime."@fr ;
          rdfs:label "Aircraft"@en ,
                     "Aéronef"@fr .


:AircraftWreck rdfs:comment "Épave d'aéronef immergée."@fr ;
               rdfs:label "Aircraft wreck"@en ,
                          "Épave d'aéronef"@fr .


:Airspace rdfs:comment "Volume d'espace aérien délimité."@fr ;
          rdfs:label "Airspace"@en ,
                     "Espace aérien"@fr .


:Altimeter rdfs:comment "Altimètre : hauteur au-dessus du fond (acoustique) ou de la surface."@fr ;
           rdfs:label "Altimeter"@en ,
                      "Altimètre"@fr .


:Anchor rdfs:comment "Ancre : objet de mouillage, posé ou croché au fond."@fr ;
        rdfs:label "Anchor"@en ,
                   "Ancre"@fr .


:AquacultureFacility rdfs:comment "Installation aquacole (cages, filières). Obstacle de subsurface mal cartographié."@fr ;
                     rdfs:label "Aquaculture facility"@en ,
                                "Installation aquacole"@fr .


:ArtificialObject rdfs:comment "Objet passif d'origine humaine : ne porte rien, n'agit pas, est perçu ou subi."@fr ;
                  rdfs:label "Artificial object"@en ,
                             "Objet artificiel"@fr .


:AssessmentCapability rdfs:comment "Capability to derive an operational assessment from available information."@en ;
                      rdfs:label "Assessment capability"@en ,
                                 "Capacité d'évaluation"@fr .


:Atmosphere rdfs:comment "Milieu gazeux au-dessus de la surface. Siège des phénomènes météorologiques et milieu de propagation des ondes radio et optiques."@fr ;
            rdfs:label "Atmosphere"@en ,
                       "Atmosphère"@fr .


:AutonomousUnderwaterVehicle rdfs:comment "AUV : opère sans contrôle temps réel d'un opérateur. Optimisé pour la collecte de données sur zone étendue."@fr ;
                             rdfs:label "AUV"@fr ,
                                        "Autonomous underwater vehicle"@en .


:BallastSystem rdfs:comment "Système de ballast : modifie la flottabilité (immersion des sous-marins, propulsion des planeurs)."@fr ;
               rdfs:label "Ballast system"@en ,
                          "Système de ballast"@fr .


:Balloon rdfs:comment "Ballon ou aérostat : plateforme aérienne à sustentation statique, longue endurance, faible manœuvrabilité."@fr ;
         rdfs:label "Ballon"@fr ,
                    "Balloon"@en .


:Battery rdfs:comment "Batterie : stockage électrochimique. Son niveau borne l'endurance — première ressource abstraite en prédicat (« autonomie suffisante »)."@fr ;
         rdfs:label "Batterie"@fr ,
                    "Battery"@en .


:Beacon rdfs:comment "Balise fixe d'aide à la navigation."@fr ;
        rdfs:label "Balise"@fr ,
                   "Beacon"@en .


:Boat rdfs:comment "Embarcation de surface de taille modeste (pêche, plaisance, servitude)."@fr ;
      rdfs:label "Bateau"@fr ,
                 "Boat"@en .


:Bomb rdfs:comment "Bombe non explosée immergée (héritage historique typique)."@fr ;
      rdfs:label "Bomb"@en ,
                 "Bombe"@fr .


:BottomMine rdfs:comment "Mine posée sur le fond. Détection par sonar imageur, signature dépendante de la nature du sédiment et de l'ensouillement."@fr ;
            rdfs:label "Bottom mine"@en ,
                       "Mine de fond"@fr .


:Breakwater rdfs:comment "Brise-lames : ouvrage de protection contre la houle."@fr ;
            rdfs:label "Breakwater"@en ,
                       "Brise-lames"@fr .


:Buoy rdfs:comment "Bouée d'aide à la navigation (flottante, mouillée)."@fr ;
      rdfs:label "Bouée"@fr ,
                 "Buoy"@en .


:CTDProbe rdfs:comment "Sonde CTD (conductivité, température, profondeur) : mesure les gradients dont dérive le profil de célérité du son."@fr ;
          rdfs:label "CTD probe"@en ,
                     "Sonde CTD"@fr .


:CableSegment rdfs:comment "Segment de câble posé ou ensouillé (télécom, énergie). Cible typique d'inspection par ROV/AUV."@fr ;
              rdfs:label "Cable segment"@en ,
                         "Segment de câble"@fr .


:Camera rdfs:comment "Caméra visible : identification à courte portée, inspection."@fr ;
        rdfs:label "Camera"@en ,
                   "Caméra"@fr .


:Chain rdfs:comment "Chaîne : élément de liaison ou de mouillage, souvent partiellement ensouillé."@fr ;
       rdfs:label "Chain"@en ,
                  "Chaîne"@fr .


:Channel rdfs:comment "Chenal : passage navigable délimité, naturel ou dragué."@fr ;
         rdfs:label "Channel"@en ,
                    "Chenal"@fr .


:ChannelMarker rdfs:comment "Marque de chenal : matérialise les limites navigables."@fr ;
               rdfs:label "Channel marker"@en ,
                          "Marque de chenal"@fr .


:ChemicalHazardObject rdfs:comment "Objet à risque chimique (fût, cargaison dangereuse immergée)."@fr ;
                      rdfs:label "Chemical hazard object"@en ,
                                 "Objet à risque chimique"@fr .


:ClassificationCapability rdfs:comment "Capacité à attribuer un type physique d'après des caractéristiques mesurées (dimensions, signature). Exclut l'identification d'allégeance — interprétation opérationnelle hors périmètre de l'ontologie."@fr ;
                          rdfs:label "Capacité de classification"@fr ,
                                     "Classification capability"@en .


:CoastalArea rdfs:comment "Zone côtière : interface terre-mer, faibles profondeurs."@fr ;
             rdfs:label "Coastal area"@en ,
                        "Zone côtière"@fr .


:CoastalInfrastructure rdfs:comment "Infrastructure côtière (ouvrages portuaires et de protection)."@fr ;
                       rdfs:label "Coastal infrastructure"@en ,
                                  "Infrastructure côtière"@fr .


:CoastalStation rdfs:comment "Station côtière : plateforme fixe à terre (surveillance, communication)."@fr ;
                rdfs:label "Coastal station"@en ,
                           "Station côtière"@fr .


:CommunicationCapability rdfs:comment "Capacité à échanger de l'information avec d'autres systèmes."@fr ;
                         rdfs:label "Capacité de communication"@fr ,
                                    "Communication capability"@en .


:CommunicationDevice rdfs:comment "Équipement de communication : transmet de l'information entre plateformes ou vers l'infrastructure."@fr ;
                     rdfs:label "Communication device"@en ,
                                "Équipement de communication"@fr .


:CommunicationLink rdfs:comment "Technical communication connection between two or more communicating entities."@en ;
                   rdfs:label "Communication link"@en ,
                              "Liaison de communication"@fr .


:CommunicationNetwork rdfs:comment "Set of communication entities and links providing connectivity."@en ;
                      rdfs:label "Communication network"@en ,
                                 "Réseau de communication"@fr .


:Compass rdfs:comment "Compas : cap magnétique ou gyroscopique."@fr ;
         rdfs:label "Compas"@fr ,
                    "Compass"@en .


:ComputingDevice rdfs:comment "Équipement de calcul embarqué."@fr ;
                 rdfs:label "Computing device"@en ,
                            "Équipement de calcul"@fr .


:Configuration rdfs:comment "Organisation physique effective des composants d'un système."@fr ;
               rdfs:label "Configuration"@en ,
                          "Configuration"@fr .


:Container rdfs:comment "Conteneur, éventuellement perdu à la mer : obstacle flottant ou posé, écho sonar caractéristique."@fr ;
           rdfs:label "Container"@en ,
                      "Conteneur"@fr .


:ControlSurface rdfs:comment "Gouverne : surface de contrôle d'attitude et de cap (safran, barres de plongée, ailerons)."@fr ;
                rdfs:label "Control surface"@en ,
                           "Gouverne"@fr .


:CoordinationCapability rdfs:comment "Capability to synchronize actions or relative states among multiple actors."@en ;
                        rdfs:label "Capacité de coordination"@fr ,
                                   "Coordination capability"@en .


:Corridor rdfs:comment "Bounded spatial passage through which movement or an operation may be organized."@en ;
          rdfs:label "Corridor"@en ,
                     "Corridor"@fr .


:Current rdfs:comment "Courant marin : déplace et fait dériver les plateformes, en particulier les plus lentes (AUV, glider, ROV) ; contraint la navigation et la tenue de trajectoire."@fr ;
         rdfs:label "Courant"@fr ,
                    "Current"@en .


:DataProcessingCapability rdfs:comment "Capacité de traitement de données à bord."@fr ;
                          rdfs:label "Capacité de traitement de données"@fr ,
                                     "Data processing capability"@en .


:DataStorage rdfs:comment "Support de stockage de données (enregistrement des mesures en mission)."@fr ;
             rdfs:label "Data storage"@en ,
                        "Stockage de données"@fr .


:DataStorageCapability rdfs:comment "Capacité de stockage de données à bord."@fr ;
                       rdfs:label "Capacité de stockage de données"@fr ,
                                  "Data storage capability"@en .


:Debris rdfs:comment "Débris ou objet perdu, posé ou dérivant. Générateur de fausses alarmes en détection."@fr ;
        rdfs:label "Debris"@en ,
                   "Débris"@fr .


:Decoy rdfs:comment "Physical object designed to create a deceptive signature or apparent target."@en ;
       rdfs:label "Decoy"@en ,
                  "Leurre"@fr .


:DemolitionCharge rdfs:comment "Charge de démolition : explosif mis en œuvre pour neutraliser un engin ou détruire une structure."@fr ;
                  rdfs:label "Charge de démolition"@fr ,
                             "Demolition charge"@en .


:DeploymentCapability rdfs:comment "Capacité à mettre à l'eau un engin ou un équipement."@fr ;
                      rdfs:label "Capacité de mise en œuvre"@fr ,
                                 "Deployment capability"@en .


:DeploymentSystem rdfs:comment "Système de mise à l'eau (LARS, portique, rampe) : déploie un engin ou un équipement depuis la plateforme porteuse."@fr ;
                  rdfs:label "Deployment system"@en ,
                             "Système de mise en œuvre"@fr .


:DepthSensor rdfs:comment "Capteur de profondeur (pression)."@fr ;
             rdfs:label "Capteur de profondeur"@fr ,
                        "Depth sensor"@en .


:DetectionCapability rdfs:comment "Capacité à constater la présence d'un objet ou d'un signal au-dessus d'un seuil (vue physique : un écho, un contact, une signature)."@fr ;
                     rdfs:label "Capacité de détection"@fr ,
                                "Detection capability"@en .


:DivingCapability rdfs:comment "Capacité à descendre en immersion (changer d'immersion vers le bas)."@fr ;
                  rdfs:label "Capacité de plongée"@fr ,
                             "Diving capability"@en .


:Dock rdfs:comment "Dock : bassin ou ouvrage d'accueil des navires."@fr ;
      rdfs:label "Dock"@en ,
                 "Dock"@fr .


:DockingCapability rdfs:comment "Capacité d'accostage ou d'amarrage à une structure (station de recharge, plateforme porteuse)."@fr ;
                   rdfs:label "Capacité d'accostage"@fr ,
                              "Docking capability"@en .


:DopplerVelocityLog rdfs:comment "Loch Doppler (DVL) : vitesse par rapport au fond par effet Doppler acoustique. Recale la dérive de la centrale inertielle."@fr ;
                    rdfs:label "DVL"@fr ,
                               "Doppler velocity log"@en .


:DriftingMine rdfs:comment "Mine dérivante, non fixée, portée par les courants."@fr ;
              rdfs:label "Drifting mine"@en ,
                         "Mine dérivante"@fr .


:EchoSounder rdfs:comment "Sondeur : mesure la profondeur sous la quille."@fr ;
             rdfs:label "Echo sounder"@en ,
                        "Sondeur"@fr .


:ElectronicWarfareCapability rdfs:comment "Capability to sense, exploit, protect or apply effects in the electromagnetic environment."@en ;
                             rdfs:label "Capacité de guerre électronique"@fr ,
                                        "Electronic warfare capability"@en .


:EmbeddedComputer rdfs:comment "Ordinateur embarqué : calculateur généraliste de la plateforme."@fr ;
                  rdfs:label "Embedded computer"@en ,
                             "Ordinateur embarqué"@fr .


:EnergyDevice rdfs:comment "Équipement énergétique : produit, stocke ou distribue l'énergie de la plateforme."@fr ;
              rdfs:label "Energy device"@en ,
                         "Équipement énergétique"@fr .


:EnergySupplyCapability rdfs:comment "Capacité d'alimentation énergétique des équipements portés."@fr ;
                        rdfs:label "Capacité d'alimentation énergétique"@fr ,
                                   "Energy supply capability"@en .


:EngagementCapability rdfs:comment "Capacité à engager une cible désignée. Distincte de la capacité de neutralisation (NeutralizationCapability), qui vise la neutralisation d'objets (p. ex. guerre des mines). L'ontologie décrit la capacité physique, pas son backend d'exécution : en première version LSGA, le résultat d'un engagement est adjugé par la cellule blanche."@fr ;
                      rdfs:label "Capacité d'engagement"@fr ,
                                 "Engagement capability"@en ;
                      :manifestKey "engage.attack_target" .


:EntityGroup rdfs:comment "Aggregate of entities considered together for a stable structural purpose. Operational group roles remain in the Scenario Model."@en ;
             rdfs:label "Entity group"@en ,
                        "Groupe d'entités"@fr .


:EnvironmentalFeature rdfs:comment "Caractéristique structurelle du milieu, quasi statique à l'échelle d'un scénario (thermocline, relief, glace)."@fr ;
                      rdfs:label "Caractéristique environnementale"@fr ,
                                 "Environmental feature"@en .


:EnvironmentalPerception rdfs:comment "Capacité à mesurer les propriétés du milieu (colonne d'eau, météo-océano)."@fr ;
                         rdfs:label "Environmental perception"@en ,
                                    "Perception environnementale"@fr .


:EnvironmentalPhenomenon rdfs:comment "Phénomène dynamique du milieu exerçant un forçage sur les plateformes (courant, vague, vent, marée)."@fr ;
                         rdfs:label "Environmental phenomenon"@en ,
                                    "Phénomène environnemental"@fr .


:EnvironmentalSensor rdfs:comment "Senseur mesurant les propriétés du milieu (colonne d'eau, météo-océano)."@fr ;
                     rdfs:label "Environmental sensor"@en ,
                                "Senseur environnemental"@fr .


:EnvironmentalState rdfs:comment "État courant du milieu à un instant donné (conditions météo-océano en vigueur)."@fr ;
                    rdfs:label "Environmental state"@en ,
                               "État environnemental"@fr .


:Equipment rdfs:comment "Système physique porté par une plateforme : senseur, actionneur, communication, calcul, énergie, stockage. Ne se déplace pas par lui-même — c'est le porteur qui bouge."@fr ;
           rdfs:label "Equipment"@en ,
                      "Équipement"@fr .


:EquipmentWreck rdfs:comment "Épave d'équipement (engin, instrument coulé)."@fr ;
                rdfs:label "Equipment wreck"@en ,
                           "Épave d'équipement"@fr .


:ExplosiveObject rdfs:comment "Objet contenant une charge explosive. Couvre les usages militaires (mines, munitions) et civils (démolition sous-marine)."@fr ;
                 rdfs:label "Explosive object"@en ,
                            "Objet explosif"@fr .


:FPGA rdfs:comment "Circuit logique programmable : traitement temps réel au plus près du senseur."@fr ;
      rdfs:label "FPGA"@en ,
                 "FPGA"@fr .


:FastAttackCraft rdfs:comment "Petite embarcation rapide et manœuvrante, faiblement armée. Sa caractéristique physique déterminante est la vitesse ; son caractère menaçant relève d'une relation de scénario (allégeance), hors de l'ontologie."@fr ;
                 rdfs:label "Fast attack craft"@en ,
                            "Vedette rapide"@fr .


:FieldPerception rdfs:comment "Perception des champs (magnétique, électrique) : détection d'anomalies causées par les masses métalliques."@fr ;
                 rdfs:label "Field perception"@en ,
                            "Perception de champ"@fr .


:FieldSensor rdfs:comment "Senseur de champ (magnétique, électrique). Détecte les perturbations locales du champ terrestre causées par les masses métalliques."@fr ;
             rdfs:label "Field sensor"@en ,
                        "Senseur de champ"@fr .


:FixedPlatform rdfs:comment "Plateforme fixe : porteur immobile d'équipements (station, bouée instrumentée)."@fr ;
               rdfs:label "Fixed platform"@en ,
                          "Plateforme fixe"@fr .


:FloatingMine rdfs:comment "Mine flottant en surface ou en subsurface immédiate."@fr ;
              rdfs:label "Floating mine"@en ,
                         "Mine flottante"@fr .


:FuelCell rdfs:comment "Pile à combustible : source électrique de longue endurance, notamment pour la propulsion anaérobie."@fr ;
          rdfs:label "Fuel cell"@en ,
                     "Pile à combustible"@fr .


:FuelTank rdfs:comment "Réservoir de carburant."@fr ;
          rdfs:label "Fuel tank"@en ,
                     "Réservoir de carburant"@fr .


:GNSSReceiver rdfs:comment "Récepteur GNSS : positionnement par constellation satellitaire. Indisponible en immersion — le sous-marin remonte ou dérive à l'estime."@fr ;
              rdfs:label "GNSS receiver"@en ,
                         "Récepteur GNSS"@fr .


:GPU rdfs:comment "Processeur graphique : calcul parallèle embarqué (traitement d'image, IA)."@fr ;
     rdfs:label "GPU"@en ,
                "Processeur graphique"@fr .


:Generator rdfs:comment "Générateur : production électrique à bord."@fr ;
           rdfs:label "Generator"@en ,
                      "Générateur"@fr .


:GroundMobility rdfs:comment "Mobilité à terre."@fr ;
                rdfs:label "Ground mobility"@en ,
                           "Mobilité terrestre"@fr .


:GroundPlatform rdfs:comment "Plateforme évoluant à terre."@fr ;
                rdfs:label "Ground platform"@en ,
                           "Plateforme terrestre"@fr .


:GunSystem rdfs:comment "Artillerie navale : arme à tir tendu et cadence élevée, portée courte à moyenne. Effecteur d'engagement de cibles proches (surface, air rapproché)."@fr ;
           rdfs:label "Gun system"@en ,
                      "Système d'artillerie"@fr .


:Halocline rdfs:comment "Couche de fort gradient de salinité. Peut générer des gradients de célérité sévères, notamment près de la surface."@fr ;
           rdfs:label "Halocline"@en ,
                      "Halocline"@fr .


:HarbourArea rdfs:comment "Zone portuaire : eaux abritées et aménagées."@fr ;
             rdfs:label "Harbour area"@en ,
                        "Zone portuaire"@fr .


:HazardousObject rdfs:comment "Objet présentant un danger intrinsèque (chimique, radioactif, explosif) indépendamment de toute intention."@fr ;
                 rdfs:label "Hazardous object"@en ,
                            "Objet dangereux"@fr .


:HealthMonitoringCapability rdfs:comment "Capacité de surveillance de l'état de santé des systèmes embarqués."@fr ;
                            rdfs:label "Capacité de surveillance de santé"@fr ,
                                       "Health monitoring capability"@en .


:Helicopter rdfs:comment "Hélicoptère : aéronef à voilure tournante, capacité de vol stationnaire, opérable depuis une plateforme navale."@fr ;
            rdfs:label "Helicopter"@en ,
                       "Hélicoptère"@fr .


:HoveringCapability rdfs:comment "Capacité de vol ou de tenue stationnaire dans le milieu."@fr ;
                    rdfs:label "Capacité de vol stationnaire"@fr ,
                               "Hovering capability"@en .


:IceFeature rdfs:comment "Formation de glace structurante du milieu (banquise, glace de mer). Contraint la navigation de surface et l'accès à la surface pour les engins sous-marins."@fr ;
            rdfs:label "Formation de glace"@fr ,
                       "Ice feature"@en .


:IceObject rdfs:comment "Objet de glace flottant ou dérivant (growler, floe). Danger de collision peu détectable au radar."@fr ;
           rdfs:label "Ice object"@en ,
                      "Objet de glace"@fr .


:IdentificationCapability rdfs:comment "Capability to establish an identity assessment for an observed entity."@en ;
                          rdfs:label "Capacité d'identification"@fr ,
                                     "Identification capability"@en .


:ImagingRadar rdfs:comment "Radar imageur ou à onde de surface haute fréquence (détection au-delà de l'horizon)."@fr ;
              rdfs:label "Imaging radar"@en ,
                         "Radar imageur"@fr .


:ImagingSonar rdfs:comment "Sonar imageur (latéral, frontal) : produit une image acoustique du fond ou de la scène. Instrument central de la détection d'objets posés."@fr ;
              rdfs:label "Imaging sonar"@en ,
                         "Sonar imageur"@fr .


:IndustrialDebris rdfs:comment "Débris d'origine industrielle (structures, équipements abandonnés)."@fr ;
                  rdfs:label "Débris industriel"@fr ,
                             "Industrial debris"@en .


:InertialNavigationSystem rdfs:comment "Centrale inertielle (INS/IMU) : mesure attitude, cap et déplacement par inertie. Seul positionnement continu en immersion ; dérive avec le temps."@fr ;
                          rdfs:label "Centrale inertielle"@fr ,
                                     "Inertial navigation system"@en .


:InfraredCamera rdfs:comment "Caméra infrarouge : détection par contraste thermique, utilisable de nuit ; inopérante sous l'eau."@fr ;
                rdfs:label "Caméra infrarouge"@fr ,
                           "Infrared camera"@en .


:Infrastructure rdfs:comment "Système physique fixe et permanent, support d'activités. Ne se déplace pas mais peut porter des équipements."@fr ;
                rdfs:label "Infrastructure"@en ,
                           "Infrastructure"@fr .


:InspectionCapability rdfs:comment "Capability to examine an object or infrastructure at the required level of detail."@en ;
                      rdfs:label "Capacité d'inspection"@fr ,
                                 "Inspection capability"@en .


:InstrumentedBuoy rdfs:comment "Bouée ou mouillage instrumenté : plateforme fixe de mesure."@fr ;
                  rdfs:label "Bouée instrumentée"@fr ,
                             "Instrumented buoy"@en .


:InteractionCapability rdfs:comment "Capacité à agir physiquement sur un objet du monde."@fr ;
                       rdfs:label "Capacité d'interaction"@fr ,
                                  "Interaction capability"@en .


:InterdictionCapability rdfs:comment "Capability to prevent, constrain, stop or control an entity, movement or activity."@en ;
                        rdfs:label "Capacité d'interdiction"@fr ,
                                   "Interdiction capability"@en .


:LaunchAndRecoveryInfrastructure rdfs:comment "Infrastructure supporting launch, docking or recovery of platforms."@en ;
                                 rdfs:label "Infrastructure de mise à l'eau et de récupération"@fr ,
                                            "Launch and recovery infrastructure"@en .


:Lidar rdfs:comment "Lidar : télémétrie laser. En version bathymétrique, pénètre les eaux claires peu profondes ; portée dégradée par la turbidité."@fr ;
       rdfs:label "Lidar"@en ,
                  "Lidar"@fr .


:Lighthouse rdfs:comment "Phare : amer lumineux majeur."@fr ;
            rdfs:label "Lighthouse"@en ,
                       "Phare"@fr .


:LocalizationCapability rdfs:comment "Capacité à estimer la position d'un objet ou la sienne propre."@fr ;
                        rdfs:label "Capacité de localisation"@fr ,
                                   "Localization capability"@en .


:LogisticsCapability rdfs:comment "Capability to resupply, transfer, refuel, recharge or otherwise sustain platforms and forces."@en ;
                     rdfs:label "Capacité logistique"@fr ,
                                "Logistics capability"@en .


:LostEquipment rdfs:comment "Équipement perdu à la mer (engin de pêche, instrument, charge)."@fr ;
               rdfs:label "Lost equipment"@en ,
                          "Équipement perdu"@fr .


:Magnetometer rdfs:comment "Magnétomètre : détecte les anomalies magnétiques (masses ferreuses immergées, UXO, épaves)."@fr ;
              rdfs:label "Magnetometer"@en ,
                         "Magnétomètre"@fr .


:ManipulationCapability rdfs:comment "Capacité à saisir, déplacer ou prélever un objet (repose sur les effecteurs de manipulation)."@fr ;
                        rdfs:label "Capacité de manipulation"@fr ,
                                   "Manipulation capability"@en .


:Manipulator rdfs:comment "Bras manipulateur / pince : saisir, déplacer, prélever un objet."@fr ;
             rdfs:label "Manipulateur"@fr ,
                        "Manipulator"@en .


:MannedSubmersible rdfs:comment "Submersible habité civil (recherche, intervention, tourisme)."@fr ;
                   rdfs:label "Manned submersible"@en ,
                              "Submersible habité"@fr .


:MarineOrganism rdfs:comment "Organisme marin (faune, banc de poissons). Source de bruit et d'échos biologiques (fausses alarmes acoustiques)."@fr ;
                rdfs:label "Marine organism"@en ,
                           "Organisme marin"@fr .


:MaritimeArea rdfs:comment "Zone maritime générique délimitée en surface."@fr ;
              rdfs:label "Maritime area"@en ,
                         "Zone maritime"@fr .


:MaritimeCriticalInfrastructure rdfs:comment "Maritime infrastructure whose loss or degradation has significant operational or societal consequences."@en ;
                                rdfs:label "Infrastructure maritime critique"@fr ,
                                           "Maritime critical infrastructure"@en .


:MaritimeEnvironmentEntity rdfs:comment "Racine des entités environnementales maritimes : caractéristiques (features) et phénomènes."@fr ;
                           rdfs:label "Entité environnementale maritime"@fr ,
                                      "Maritime environment entity"@en .


:MaritimeInfrastructure rdfs:comment "Infrastructure liée au milieu maritime (côtière, offshore, sous-marine, de navigation)."@fr ;
                        rdfs:label "Infrastructure maritime"@fr ,
                                   "Maritime infrastructure"@en .


:MarkingCapability rdfs:comment "Capacité à déposer une marque sur ou près d'un objet localisé."@fr ;
                   rdfs:label "Capacité de balisage"@fr ,
                              "Marking capability"@en .


:MarkingSystem rdfs:comment "Système de balisage d'objets : dépose une marque sur ou près d'un objet localisé (contexte typique : marquage d'engins avant neutralisation)."@fr ;
               rdfs:label "Marking system"@en ,
                          "Système de balisage"@fr .


:Materiel rdfs:comment "Physical supplies, equipment or goods transported, transferred or consumed in support activities."@en ;
          rdfs:label "Materiel"@en ,
                     "Matériel"@fr .


:MerchantShip rdfs:comment "Navire de surface civil de transport (cargo, pétrolier, porte-conteneurs). Généralement non armé ; objet de protection ou de menace dans les scénarios d'escorte."@fr ;
              rdfs:label "Merchant ship"@en ,
                         "Navire de commerce"@fr .


:MeteorologicalSensor rdfs:comment "Capteur météorologique (vent, pression, température de l'air)."@fr ;
                      rdfs:label "Capteur météorologique"@fr ,
                                 "Meteorological sensor"@en .


:MilitaryPayload rdfs:comment "Payload specifically designed for a military operational purpose."@en ;
                 rdfs:label "Charge utile militaire"@fr ,
                            "Military payload"@en .


:MissileSystem rdfs:comment "Système de missiles embarqués : effecteur d'engagement de cibles à moyenne ou longue portée."@fr ;
               rdfs:label "Missile system"@en ,
                          "Système de missiles"@fr .


:MobilityCapability rdfs:comment "Capacité à se déplacer dans un milieu."@fr ;
                    rdfs:label "Capacité de mobilité"@fr ,
                               "Mobility capability"@en .


:MooredMine rdfs:comment "Mine à orin : flottante entre deux eaux, reliée au fond par un câble. Détectable dans la colonne d'eau."@fr ;
            rdfs:label "Mine à orin"@fr ,
                       "Moored mine"@en .


:MooringElement rdfs:comment "Élément de ligne de mouillage (corps-mort, flotteur intermédiaire, ligne)."@fr ;
                rdfs:label "Mooring element"@en ,
                           "Élément de mouillage"@fr .


:MooringSystem rdfs:comment "Système de mouillage de navigation (coffre, ligne de mouillage). Distinct du mouillage de mines, sans équivalent dans cette version."@fr ;
               rdfs:label "Mooring system"@en ,
                          "Système de mouillage"@fr .


:MultibeamSonar rdfs:comment "Sonar multifaisceaux : bathymétrie et imagerie de la colonne d'eau par balayage. Outil hydrographique standard."@fr ;
                rdfs:label "Multibeam sonar"@en ,
                           "Sonar multifaisceaux"@fr .


:NaturalObject rdfs:comment "Objet passif d'origine naturelle présent dans le milieu."@fr ;
               rdfs:label "Natural object"@en ,
                          "Objet naturel"@fr .


:NavalBase rdfs:comment "Military infrastructure supporting naval command, logistics, maintenance, berthing and operations. It may contain a harbour but is not a subclass of Harbour."@en ;
           rdfs:label "Base navale"@fr ,
                      "Naval base"@en .


:NavalMine rdfs:comment "Mine navale : engin explosif déposé volontairement dans le milieu. Passive une fois posée."@fr ;
           rdfs:label "Mine navale"@fr ,
                      "Naval mine"@en .


:NavigationCapability rdfs:comment "Capacité de conduite du déplacement : savoir où l'on est et rejoindre où l'on va."@fr ;
                      rdfs:label "Capacité de navigation"@fr ,
                                 "Navigation capability"@en .


:NavigationInfrastructure rdfs:comment "Aide à la navigation passive : balise, bouée, marque, phare."@fr ;
                          rdfs:label "Infrastructure de navigation"@fr ,
                                     "Navigation infrastructure"@en .


:NavigationRadar rdfs:comment "Radar de navigation : anticollision et situation de surface. Détection des petits objets dégradée par l'état de mer."@fr ;
                 rdfs:label "Navigation radar"@en ,
                            "Radar de navigation"@fr .


:NavigationSensor rdfs:comment "Senseur de navigation : fournit position, cap, vitesse ou profondeur à la plateforme porteuse."@fr ;
                  rdfs:label "Navigation sensor"@en ,
                             "Senseur de navigation"@fr .


:NeutralizationCapability rdfs:comment "Capacité à rendre un engin inopérant par effet physique (charge de neutralisation, émetteur d'influence). Distincte de l'engagement d'une cible (EngagementCapability)."@fr ;
                          rdfs:label "Capacité de neutralisation"@fr ,
                                     "Neutralization capability"@en .


:NeutralizationSystem rdfs:comment "Système de neutralisation : met en œuvre l'effet rendant un engin inopérant (charge, émetteur d'influence)."@fr ;
                      rdfs:label "Neutralization system"@en ,
                                 "Système de neutralisation"@fr .


:ObstacleAvoidanceCapability rdfs:comment "Capacité d'évitement d'obstacles en cours de route."@fr ;
                             rdfs:label "Capacité d'évitement d'obstacles"@fr ,
                                        "Obstacle avoidance capability"@en .


:OceanographicSensor rdfs:comment "Capteur océanographique (propriétés de la colonne d'eau)."@fr ;
                     rdfs:label "Capteur océanographique"@fr ,
                                "Oceanographic sensor"@en .


:OffshoreInfrastructure rdfs:comment "Infrastructure en mer ouverte (plateforme, éolienne, aquaculture)."@fr ;
                        rdfs:label "Infrastructure offshore"@fr ,
                                   "Offshore infrastructure"@en .


:OffshoreMonitoringStation rdfs:comment "Station de surveillance offshore fixe."@fr ;
                           rdfs:label "Offshore monitoring station"@en ,
                                      "Station de surveillance offshore"@fr .


:OffshorePlatform rdfs:comment "Plateforme offshore fixe ou flottante (énergie, industrie)."@fr ;
                  rdfs:label "Offshore platform"@en ,
                             "Plateforme offshore"@fr .


:OpticalCommunication rdfs:comment "Communication optique sous-marine : très haut débit, très courte portée, eaux claires."@fr ;
                      rdfs:label "Communication optique"@fr ,
                                 "Optical communication"@en .


:OpticalCommunicationDevice rdfs:comment "Équipement de communication optique : très haut débit sous-marin à très courte portée, en eaux claires."@fr ;
                            rdfs:label "Optical communication device"@en ,
                                       "Équipement de communication optique"@fr .


:OpticalPerception rdfs:comment "Perception par voie optique, à courte portée sous l'eau (turbidité)."@fr ;
                   rdfs:label "Optical perception"@en ,
                              "Perception optique"@fr .


:OpticalSensor rdfs:comment "Senseur optique. Portée fortement dégradée par la turbidité de l'eau ; usage sous-marin à courte distance seulement."@fr ;
               rdfs:label "Optical sensor"@en ,
                          "Senseur optique"@fr .


:PassiveSonar rdfs:comment "Sonar passif / hydrophone : écoute sans émettre. En réseau, fournit une localisation spatiale (détection/classification de contacts)."@fr ;
              rdfs:label "Passive sonar"@en ,
                         "Sonar passif"@fr .


:Payload rdfs:comment "Equipment or material carried by a platform for an operational purpose."@en ;
         rdfs:label "Charge utile"@fr ,
                    "Payload"@en .


:PayloadHostingCapability rdfs:comment "Capacité d'emport : accueillir, alimenter et interfacer une charge utile."@fr ;
                          rdfs:label "Capacité d'emport"@fr ,
                                     "Payload hosting capability"@en .


:PerceptionCapability rdfs:comment "Capacité à percevoir le monde au travers de senseurs."@fr ;
                      rdfs:label "Capacité de perception"@fr ,
                                 "Perception capability"@en .


:Person rdfs:comment "Human physical entity represented in a maritime scenario."@en ;
        rdfs:label "Person"@en ,
                   "Personne"@fr .


:PersonnelGroup rdfs:comment "Collection of persons considered as one structural aggregate."@en ;
                rdfs:label "Groupe de personnel"@fr ,
                           "Personnel group"@en .


:PhysicalCapability rdfs:comment "Fonction qu'un système physique est susceptible de fournir selon son type, sa configuration et son état."@fr ;
                    rdfs:label "Capacité physique"@fr ,
                               "Physical capability"@en .


:PhysicalEntity rdfs:comment "Toute entité ayant une existence physique dans le monde simulé."@fr ;
                rdfs:label "Entité physique"@fr ,
                           "Physical entity"@en .


:PhysicalMedium rdfs:comment "Milieu physique de propagation et d'évolution (atmosphère, colonne d'eau, fond). Détermine quels senseurs et quelles communications sont opérants."@fr ;
                rdfs:label "Milieu physique"@fr ,
                           "Physical medium"@en .


:PhysicalObject rdfs:comment "Entité matérielle considérée principalement comme un objet, sans exigence de composition fonctionnelle."@fr ;
                rdfs:label "Objet physique"@fr ,
                           "Physical object"@en ;
                <http://www.w3.org/2004/02/skos/core#closeMatch> <http://www.w3.org/ns/sosa/FeatureOfInterest> .


:PhysicalProperty rdfs:comment "Caractéristique physique mesurable d'une entité. Alignée sur sosa:ObservableProperty."@fr ;
                  rdfs:label "Physical property"@en ,
                             "Propriété physique"@fr ;
                  <http://www.w3.org/2004/02/skos/core#closeMatch> <http://www.w3.org/ns/sosa/ObservableProperty> .


:PhysicalState rdfs:comment "État instantané d'une entité physique."@fr ;
               rdfs:label "Physical state"@en ,
                          "État physique"@fr .


:PhysicalSubstance rdfs:comment "Substance physique (matière sans individualité d'objet)."@fr ;
                   rdfs:label "Physical substance"@en ,
                              "Substance physique"@fr .


:PhysicalSystem rdfs:comment "Entité physique composée de parties organisées remplissant une ou plusieurs fonctions."@fr ;
                rdfs:label "Physical system"@en ,
                           "Système physique"@fr ;
                <http://www.w3.org/2004/02/skos/core#closeMatch> <http://www.w3.org/ns/ssn/System> .


:Pier rdfs:comment "Jetée : ouvrage avancé en mer, accostage et protection."@fr ;
      rdfs:label "Jetée"@fr ,
                 "Pier"@en .


:PipeSegment rdfs:comment "Segment de conduite posé ou ensouillé. Cible typique d'inspection."@fr ;
             rdfs:label "Pipe segment"@en ,
                        "Segment de conduite"@fr .


:Platform rdfs:comment "Système physique servant de porteur à des équipements."@fr ;
          rdfs:label "Plateforme"@fr ,
                     "Platform"@en .


:PlatformGroup rdfs:comment "Collection of platforms considered as one aggregate. Convoy, task group, swarm and escort group are scenario roles, not ontology subclasses."@en ;
               rdfs:label "Groupe de plateformes"@fr ,
                          "Platform group"@en .


:PortInfrastructure rdfs:comment "Infrastructure portuaire générale."@fr ;
                    rdfs:label "Infrastructure portuaire"@fr ,
                               "Port infrastructure"@en .


:PositionEstimationCapability rdfs:comment "Capacité d'estimation de position propre par fusion de senseurs de navigation."@fr ;
                              rdfs:label "Capacité d'estimation de position"@fr ,
                                         "Position estimation capability"@en .


:PropertyValue rdfs:comment "Valeur datée d'une propriété pour une entité (patron de réification propriété-valeur)."@fr ;
               rdfs:label "Property value"@en ,
                          "Valeur de propriété"@fr .


:PropulsionSystem rdfs:comment "Système de propulsion principale ou d'appoint (hélice, hydrojet, thrusters vectoriels des ROV/AUV, rotors)."@fr ;
                  rdfs:label "Propulsion system"@en ,
                             "Système de propulsion"@fr .


:ProtectionCapability rdfs:comment "Capability to preserve another entity, group, area, infrastructure or service against harmful effects."@en ;
                      rdfs:label "Capacité de protection"@fr ,
                                 "Protection capability"@en .


:Pycnocline rdfs:comment "Couche de fort gradient de densité (combinaison des gradients de température et de salinité). Barrière physique au mélange vertical."@fr ;
            rdfs:label "Pycnocline"@en ,
                       "Pycnocline"@fr .


:Quay rdfs:comment "Quai : ouvrage d'accostage à terre."@fr ;
      rdfs:label "Quai"@fr ,
                 "Quay"@en .


:RadioCommunication rdfs:comment "Communication radio : surface et air uniquement."@fr ;
                    rdfs:label "Communication radio"@fr ,
                               "Radio communication"@en .


:RadioFrequencyPerception rdfs:comment "Perception radioélectrique, en surface et dans l'air uniquement."@fr ;
                          rdfs:label "Perception radioélectrique"@fr ,
                                     "Radio-frequency perception"@en .


:RadioFrequencySensor rdfs:comment "Senseur radioélectrique. Les ondes radio ne pénètrent pratiquement pas l'eau de mer : usage limité à la surface et à l'air."@fr ;
                      rdfs:label "Radio-frequency sensor"@en ,
                                 "Senseur radioélectrique"@fr .


:RadioTransceiver rdfs:comment "Émetteur-récepteur radio : liaison de surface et aérienne. Inopérant sous l'eau."@fr ;
                  rdfs:label "Radio transceiver"@en ,
                             "Émetteur-récepteur radio"@fr .


:RadioactiveObject rdfs:comment "Objet à risque radiologique immergé."@fr ;
                   rdfs:label "Objet radioactif"@fr ,
                              "Radioactive object"@en .


:RecoveryCapability rdfs:comment "Capacité à récupérer un engin ou un équipement. Opération sensible à l'état de mer."@fr ;
                    rdfs:label "Capacité de récupération"@fr ,
                               "Recovery capability"@en .


:RecoverySystem rdfs:comment "Système de récupération : reprend à bord un engin ou un équipement. Opération sensible à l'état de mer."@fr ;
                rdfs:label "Recovery system"@en ,
                           "Système de récupération"@fr .


:Reef rdfs:comment "Récif : haut-fond rocheux ou corallien. Danger pour la navigation, relief de masquage acoustique."@fr ;
      rdfs:label "Reef"@en ,
                 "Récif"@fr .


:RelayCapability rdfs:comment "Capability to relay communications between otherwise disconnected or range-limited entities."@en ;
                 rdfs:label "Capacité de relais"@fr ,
                            "Relay capability"@en .


:RemotelyOperatedVehicle rdfs:comment "ROV : relié par ombilical, contrôlé en temps réel. Adapté aux interventions et manipulations délicates."@fr ;
                         rdfs:label "ROV"@fr ,
                                    "Remotely operated vehicle"@en .


:RestrictedArea rdfs:comment "Zone d'accès restreint ou réglementé, quelle qu'en soit la raison (réglementaire, sécurité, environnementale)."@fr ;
                rdfs:label "Restricted area"@en ,
                           "Zone restreinte"@fr .


:Rock rdfs:comment "Rocher isolé sur le fond ou affleurant. Écho ponctuel dur, confusable avec un objet artificiel."@fr ;
      rdfs:label "Rocher"@fr ,
                 "Rock"@en .


:Route rdfs:comment "Ordered spatial path used to organize movement between locations."@en ;
       rdfs:label "Route"@en ,
                  "Route"@fr .


:RouteFollowingCapability rdfs:comment "Capacité de suivi d'une route planifiée."@fr ;
                          rdfs:label "Capacité de suivi de route"@fr ,
                                     "Route-following capability"@en .


:SailingPlatform rdfs:comment "Plateforme à propulsion vélique. La navigation s'y fait par rapport au vent (tirer des bords) — cas d'école d'une autonomie spécifique à la plateforme."@fr ;
                 rdfs:label "Plateforme à voile"@fr ,
                            "Sailing platform"@en .


:SamplingCapability rdfs:comment "Capacité à prélever un échantillon du milieu ou du fond."@fr ;
                    rdfs:label "Capacité de prélèvement"@fr ,
                               "Sampling capability"@en .


:SamplingSystem rdfs:comment "Système de prélèvement : échantillonne le milieu ou le fond."@fr ;
                rdfs:label "Sampling system"@en ,
                           "Système de prélèvement"@fr .


:SatelliteCommunication rdfs:comment "Communication satellite : longue portée, en surface ou émersion."@fr ;
                        rdfs:label "Communication satellite"@fr ,
                                   "Satellite communication"@en .


:SatellitePlatform rdfs:comment "Plateforme satellitaire (observation, communication, positionnement)."@fr ;
                   rdfs:label "Plateforme satellitaire"@fr ,
                              "Satellite platform"@en .


:SatelliteTerminal rdfs:comment "Terminal satellite : liaison longue portée, en surface ou émersion uniquement."@fr ;
                   rdfs:label "Satellite terminal"@en ,
                              "Terminal satellite"@fr .


:Seabed rdfs:comment "Substrat au fond de l'eau. Sa composition et sa texture (vase, sable, roche) sont déterminées par rétrodiffusion acoustique et gouvernent la réverbération et la détection d'objets posés."@fr ;
        rdfs:label "Fond marin"@fr ,
                   "Seabed"@en .


:SeabedArea rdfs:comment "Zone délimitée du fond marin (emprise 2D sur le fond)."@fr ;
            rdfs:label "Seabed area"@en ,
                       "Zone de fond marin"@fr .


:SeabedRelief rdfs:comment "Topographie du fond et profondeur. Crée masques et zones d'ombre pour la détection."@fr ;
              rdfs:label "Relief du fond"@fr ,
                         "Seabed relief"@en .


:SedimentTransport rdfs:comment "Déplacement de sédiments par les courants. Modifie la turbidité, peut ensevelir progressivement les objets posés."@fr ;
                   rdfs:label "Sediment transport"@en ,
                              "Transport sédimentaire"@fr .


:SelfMonitoringCapability rdfs:comment "Capacité d'auto-surveillance de la plateforme (état interne, ressources)."@fr ;
                          rdfs:label "Capacité d'auto-surveillance"@fr ,
                                     "Self-monitoring capability"@en .


:Sensor rdfs:comment "Dispositif physique réalisant une observation d'une propriété du monde. Aligné sur sosa:Sensor."@fr ;
        rdfs:label "Senseur"@fr ,
                   "Sensor"@en .


:Shell rdfs:comment "Obus non explosé immergé."@fr ;
       rdfs:label "Obus"@fr ,
                  "Shell"@en .


:Ship rdfs:comment "Navire : bâtiment de surface de taille significative. Classe générique — les spécialisations (combat, commerce, travaux) restent à introduire."@fr ;
      rdfs:label "Navire"@fr ,
                 "Ship"@en .


:ShipDebris rdfs:comment "Débris provenant d'un navire."@fr ;
            rdfs:label "Débris de navire"@fr ,
                       "Ship debris"@en .


:Shipwreck rdfs:comment "Épave de navire. Repère sonar fort, abri biologique, source de fausses alarmes en chasse aux mines."@fr ;
           rdfs:label "Shipwreck"@en ,
                      "Épave de navire"@fr .


:SolarPanel rdfs:comment "Panneau solaire : recharge des plateformes de surface longue endurance."@fr ;
            rdfs:label "Panneau solaire"@fr ,
                       "Solar panel"@en .


:SpatialRegion rdfs:comment "Emprise spatiale (le « où »). Support de la géométrie, alignée sur geo:Feature (GeoSPARQL). Vocabulaire des zones du schéma de scénario."@fr ;
               rdfs:label "Région spatiale"@fr ,
                          "Spatial region"@en .


:StationKeepingCapability rdfs:comment "Capacité à maintenir une position fixe malgré les forçages dynamiques (courant, vent). Distincte du suivi de cible mobile (TargetFollowingCapability)."@fr ;
                          rdfs:label "Capacité de maintien en position"@fr ,
                                     "Station-keeping capability"@en .


:StorageDevice rdfs:comment "Équipement de stockage embarqué."@fr ;
               rdfs:label "Storage device"@en ,
                          "Équipement de stockage"@fr .


:Stratification rdfs:comment "Organisation de la colonne d'eau en couches de propriétés distinctes. Cadre d'ensemble des clines (thermo-, halo-, pycnocline)."@fr ;
                rdfs:label "Stratification"@en ,
                           "Stratification"@fr .


:Submarine rdfs:comment "Sous-marin habité, à vocation essentiellement militaire (le submersible civil est MannedSubmersible)."@fr ;
           rdfs:label "Sous-marin"@fr ,
                      "Submarine"@en .


:SubmarineCable rdfs:comment "Câble sous-marin de télécommunication ou d'énergie."@fr ;
                rdfs:label "Câble sous-marin"@fr ,
                           "Submarine cable"@en .


:SubseaInfrastructure rdfs:comment "Infrastructure posée sur le fond ou ensouillée (câbles, pipelines, têtes de puits). Cible typique d'inspection."@fr ;
                      rdfs:label "Infrastructure sous-marine"@fr ,
                                 "Subsea infrastructure"@en .


:SubseaManifold rdfs:comment "Collecteur sous-marin (nœud de production pétrolière/gazière)."@fr ;
                rdfs:label "Collecteur sous-marin"@fr ,
                           "Subsea manifold"@en .


:SubseaPipeline rdfs:comment "Pipeline sous-marin."@fr ;
                rdfs:label "Pipeline sous-marin"@fr ,
                           "Subsea pipeline"@en .


:SubseaStation rdfs:comment "Station sous-marine posée (observatoire, nœud de recharge ou de communication)."@fr ;
               rdfs:label "Station sous-marine"@fr ,
                          "Subsea station"@en .


:SubseaWellhead rdfs:comment "Tête de puits sous-marine."@fr ;
                rdfs:label "Subsea wellhead"@en ,
                           "Tête de puits sous-marine"@fr .


:SupportCapability rdfs:comment "Capacité de soutien interne à la plateforme (énergie, calcul, stockage, emport)."@fr ;
                   rdfs:label "Capacité de soutien"@fr ,
                              "Support capability"@en .


:SurfaceBuoy rdfs:comment "Bouée de surface considérée comme plateforme : porte des équipements."@fr ;
