@prefix : <https://ontology.lotusim.org/naval-maritime#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://ontology.lotusim.org/naval-maritime#> .

<https://ontology.lotusim.org/naval-maritime> rdf:type owl:Ontology ;
                                               <http://purl.org/dc/terms/creator> "Estelle Chauveau (Naval Group, PO LOTUSim)" ;
                                               <http://purl.org/dc/terms/description> "Physical-world ontology for LOTUSim covering systems, platforms, equipment, physical objects, infrastructure, maritime environment, states, configurations, properties and physical capabilities."@en ;
                                               <http://purl.org/dc/terms/modified> "2026-07-13"^^xsd:date ;
                                               <http://purl.org/dc/terms/publisher> "Naval Group" ;
                                               <http://purl.org/dc/terms/title> "LOTUSim Naval Maritime Ontology"@en ;
                                               rdfs:comment "Ontologie de référence décrivant le monde naval physique simulable à un instant donné. Elle exclut les missions, objectifs, tâches, rôles opérationnels, observations, événements, doctrine et planification."@fr ,
                                                            "Vocabulaire normatif de LOTUSim : les types du profil HDDL, le vocabulaire du schéma de scénario (agents, zones) et les familles des manifestes de capacités (nmo:manifestKey) en dérivent. Chaque classe porte une annotation de diffusabilité (nmo:hasUsageDomain : civil / dual-use / militaire) conditionnant sa présence dans les exports publics."@fr ;
                                               rdfs:label "LOTUSim Naval Maritime Ontology"@en ,
                                                          "Ontologie navale maritime LOTUSim"@fr ;
                                               owl:versionInfo "2.0.0-draft" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
<http://purl.org/dc/terms/modified> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/publisher
<http://purl.org/dc/terms/publisher> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#closeMatch
<http://www.w3.org/2004/02/skos/core#closeMatch> rdf:type owl:AnnotationProperty .


###  https://ontology.lotusim.org/naval-maritime#manifestKey
:manifestKey rdf:type owl:AnnotationProperty ;
             rdfs:comment "Identifiant normatif de famille d'actions typées dans les manifestes de capacités (contrat supervision-guidage, LSGA v3 §4.3). Notation pointée famille.action. Les manifestes des autonomies référencent ces clés définies par l'ontologie ; ils n'en créent jamais."@fr ;
             rdfs:label "clé de manifeste"@fr ,
                        "manifest key"@en ;
             rdfs:range xsd:string .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://ontology.lotusim.org/naval-maritime#affectedByPhenomenon
:affectedByPhenomenon rdf:type owl:ObjectProperty ;
                      rdfs:domain :PhysicalEntity ;
                      rdfs:range :EnvironmentalPhenomenon ;
                      rdfs:label "affected by phenomenon"@en ,
                                 "est affecté par le phénomène"@fr .


###  https://ontology.lotusim.org/naval-maritime#anchoredTo
:anchoredTo rdf:type owl:ObjectProperty ;
            rdfs:domain :PhysicalEntity ;
            rdfs:range :PhysicalEntity ;
            rdfs:label "anchored to"@en ,
                       "est ancré à"@fr .


###  https://ontology.lotusim.org/naval-maritime#attachedTo
:attachedTo rdf:type owl:ObjectProperty ;
            rdfs:domain :PhysicalEntity ;
            rdfs:range :PhysicalEntity ;
            rdfs:label "attached to"@en ,
                       "est attaché à"@fr .


###  https://ontology.lotusim.org/naval-maritime#buriedIn
:buriedIn rdf:type owl:ObjectProperty ;
          rdfs:domain :PhysicalEntity ;
          rdfs:range :PhysicalMedium ;
          rdfs:label "buried in"@en ,
                     "est enfoui dans"@fr .


###  https://ontology.lotusim.org/naval-maritime#capabilityAvailabilityLimitedBy
:capabilityAvailabilityLimitedBy rdf:type owl:ObjectProperty ;
                                 rdfs:domain :PhysicalCapability ;
                                 rdfs:range :PhysicalState ;
                                 rdfs:label "capability availability limited by"@en ,
                                            "disponibilité limitée par"@fr .


###  https://ontology.lotusim.org/naval-maritime#configurationOf
:configurationOf rdf:type owl:ObjectProperty ;
                 owl:inverseOf :hasConfiguration ;
                 rdf:type owl:FunctionalProperty ;
                 rdfs:domain :Configuration ;
                 rdfs:range :PhysicalSystem ;
                 rdfs:label "configuration de"@fr ,
                            "configuration of"@en .


###  https://ontology.lotusim.org/naval-maritime#connectedTo
:connectedTo rdf:type owl:ObjectProperty ;
             rdfs:domain :PhysicalEntity ;
             rdfs:range :PhysicalEntity ;
             rdfs:label "connected to"@en ,
                        "est connecté à"@fr .


###  https://ontology.lotusim.org/naval-maritime#containsPhysicalEntity
:containsPhysicalEntity rdf:type owl:ObjectProperty ;
                        owl:inverseOf :locatedIn ;
                        rdfs:domain :SpatialRegion ;
                        rdfs:range :PhysicalEntity ;
                        rdfs:label "contains physical entity"@en ,
                                   "contient l'entité physique"@fr .


###  https://ontology.lotusim.org/naval-maritime#contributesToCapability
:contributesToCapability rdf:type owl:ObjectProperty ;
                         rdfs:domain :Equipment ;
                         rdfs:range :PhysicalCapability ;
                         rdfs:label "contribue à la capacité"@fr ,
                                    "contributes to capability"@en .


###  https://ontology.lotusim.org/naval-maritime#enablesCapability
:enablesCapability rdf:type owl:ObjectProperty ;
                   rdfs:domain :Configuration ;
                   rdfs:range :PhysicalCapability ;
                   rdfs:label "active la capacité"@fr ,
                              "enables capability"@en .


###  https://ontology.lotusim.org/naval-maritime#floatingOn
:floatingOn rdf:type owl:ObjectProperty ;
            rdfs:domain :PhysicalEntity ;
            rdfs:range :WaterVolume ;
            rdfs:label "floating on"@en ,
                       "flotte sur"@fr .


###  https://ontology.lotusim.org/naval-maritime#hasAvailableCapability
:hasAvailableCapability rdf:type owl:ObjectProperty ;
                        rdfs:domain :PhysicalSystem ;
                        rdfs:range :PhysicalCapability ;
                        rdfs:label "a pour capacité disponible"@fr ,
                                   "has available capability"@en .


###  https://ontology.lotusim.org/naval-maritime#hasConfiguration
:hasConfiguration rdf:type owl:ObjectProperty ,
                           owl:FunctionalProperty ;
                  rdfs:domain :PhysicalSystem ;
                  rdfs:range :Configuration ;
                  rdfs:label "a pour configuration"@fr ,
                             "has configuration"@en .


###  https://ontology.lotusim.org/naval-maritime#hasEnvironmentalFeature
:hasEnvironmentalFeature rdf:type owl:ObjectProperty ;
                         rdfs:domain :SpatialRegion ;
                         rdfs:range :EnvironmentalFeature ;
                         rdfs:label "a pour caractéristique environnementale"@fr ,
                                    "has environmental feature"@en .


###  https://ontology.lotusim.org/naval-maritime#hasEnvironmentalState
:hasEnvironmentalState rdf:type owl:ObjectProperty ;
                       rdfs:domain :PhysicalMedium ;
                       rdfs:range :EnvironmentalState ;
                       rdfs:label "a pour état environnemental"@fr ,
                                  "has environmental state"@en .


###  https://ontology.lotusim.org/naval-maritime#hasMedium
:hasMedium rdf:type owl:ObjectProperty ;
           rdfs:domain :SpatialRegion ;
           rdfs:range :PhysicalMedium ;
           rdfs:label "a pour milieu"@fr ,
                      "has medium"@en .


###  https://ontology.lotusim.org/naval-maritime#hasMember
:hasMember rdf:type owl:ObjectProperty ;
           rdfs:domain :EntityGroup ;
           rdfs:range :Entity ;
           rdfs:label "a pour membre"@fr ,
                      "has member"@en .


###  https://ontology.lotusim.org/naval-maritime#hasPhysicalPart
:hasPhysicalPart rdf:type owl:ObjectProperty ;
                 owl:inverseOf :isPhysicalPartOf ;
                 rdf:type owl:TransitiveProperty ;
                 rdfs:domain :PhysicalSystem ;
                 rdfs:range :PhysicalEntity ;
                 rdfs:label "a pour partie physique"@fr ,
                            "has physical part"@en .


###  https://ontology.lotusim.org/naval-maritime#hasPotentialCapability
:hasPotentialCapability rdf:type owl:ObjectProperty ;
                        rdfs:domain :SystemModel ;
                        rdfs:range :PhysicalCapability ;
                        rdfs:label "a pour capacité potentielle"@fr ,
                                   "has potential capability"@en .


###  https://ontology.lotusim.org/naval-maritime#hasPropertyValue
:hasPropertyValue rdf:type owl:ObjectProperty ;
                  rdfs:domain :PhysicalState ;
                  rdfs:range :PropertyValue ;
                  rdfs:label "a pour valeur de propriété"@fr ,
                             "has property value"@en .


###  https://ontology.lotusim.org/naval-maritime#hasState
:hasState rdf:type owl:ObjectProperty ;
          rdfs:domain :PhysicalEntity ;
          rdfs:range :PhysicalState ;
          rdfs:label "a pour état"@fr ,
                     "has state"@en .


###  https://ontology.lotusim.org/naval-maritime#hasSystemModel
:hasSystemModel rdf:type owl:ObjectProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain :PhysicalSystem ;
                rdfs:range :SystemModel ;
                rdfs:label "a pour modèle de système"@fr ,
                           "has system model"@en .


###  https://ontology.lotusim.org/naval-maritime#hasUsageDomain
:hasUsageDomain rdf:type owl:ObjectProperty ;
                rdfs:range :UsageDomain ;
                rdfs:label "a pour domaine d'usage"@fr ,
                           "has usage domain"@en .


###  https://ontology.lotusim.org/naval-maritime#includesEquipment
:includesEquipment rdf:type owl:ObjectProperty ;
                   rdfs:domain :Configuration ;
                   rdfs:range :Equipment ;
                   rdfs:label "includes equipment"@en ,
                              "inclut l'équipement"@fr .


###  https://ontology.lotusim.org/naval-maritime#installedAsPayload
:installedAsPayload rdf:type owl:ObjectProperty ;
                    rdfs:domain :Equipment ;
                    rdfs:range :Configuration ;
                    rdfs:label "est installé comme charge utile dans"@fr ,
                               "installed as payload"@en .


###  https://ontology.lotusim.org/naval-maritime#installedOn
:installedOn rdf:type owl:ObjectProperty ;
             rdfs:domain :Equipment ;
             rdfs:range :PhysicalSystem ;
             rdfs:label "est installé sur"@fr ,
                        "installed on"@en .


###  https://ontology.lotusim.org/naval-maritime#isPhysicalPartOf
:isPhysicalPartOf rdf:type owl:ObjectProperty ,
                           owl:TransitiveProperty ;
                  rdfs:domain :PhysicalEntity ;
                  rdfs:range :PhysicalSystem ;
                  rdfs:label "est une partie physique de"@fr ,
                             "is physical part of"@en .


###  https://ontology.lotusim.org/naval-maritime#laidOn
:laidOn rdf:type owl:ObjectProperty ;
        rdfs:domain :PhysicalEntity ;
        rdfs:range :SeabedArea ;
        rdfs:label "est posé sur"@fr ,
                   "laid on"@en .


###  https://ontology.lotusim.org/naval-maritime#locatedIn
:locatedIn rdf:type owl:ObjectProperty ;
           rdfs:domain :PhysicalEntity ;
           rdfs:range :SpatialRegion ;
           rdfs:label "est localisé dans"@fr ,
                      "located in"@en .


###  https://ontology.lotusim.org/naval-maritime#mooredTo
:mooredTo rdf:type owl:ObjectProperty ;
          rdfs:domain :PhysicalEntity ;
          rdfs:range :PhysicalEntity ;
          rdfs:label "est amarré à"@fr ,
                     "moored to"@en .


###  https://ontology.lotusim.org/naval-maritime#poweredBy
:poweredBy rdf:type owl:ObjectProperty ;
           rdfs:domain :PhysicalSystem ;
           rdfs:range :EnergyDevice ;
           rdfs:label "est alimenté par"@fr ,
                      "powered by"@en .


###  https://ontology.lotusim.org/naval-maritime#stateOf
:stateOf rdf:type owl:ObjectProperty ;
         owl:inverseOf :hasState ;
         rdfs:domain :PhysicalState ;
         rdfs:range :PhysicalEntity ;
         rdfs:label "state of"@en ,
                    "état de"@fr .


###  https://ontology.lotusim.org/naval-maritime#submergedIn
:submergedIn rdf:type owl:ObjectProperty ;
             rdfs:domain :PhysicalEntity ;
             rdfs:range :WaterVolume ;
             rdfs:label "est immergé dans"@fr ,
                        "submerged in"@en .


###  https://ontology.lotusim.org/naval-maritime#valueForProperty
:valueForProperty rdf:type owl:ObjectProperty ,
                           owl:FunctionalProperty ;
                  rdfs:domain :PropertyValue ;
                  rdfs:range :PhysicalProperty ;
                  rdfs:label "valeur de la propriété"@fr ,
                             "value for property"@en .


#################################################################
#    Data properties
#################################################################

###  https://ontology.lotusim.org/naval-maritime#altitude
:altitude rdf:type owl:DatatypeProperty ;
          rdfs:domain :PhysicalState ;
          rdfs:range xsd:decimal ;
          rdfs:label "altitude"@en ,
                     "altitude"@fr ;
          <http://www.w3.org/2004/02/skos/core#closeMatch> <http://www.w3.org/2003/01/geo/wgs84_pos#alt> .


###  https://ontology.lotusim.org/naval-maritime#batteryLevel
:batteryLevel rdf:type owl:DatatypeProperty ;
              rdfs:domain :SystemState ;
              rdfs:range xsd:decimal ;
              rdfs:label "battery level"@en ,
                         "niveau de batterie"@fr .


###  https://ontology.lotusim.org/naval-maritime#depth
:depth rdf:type owl:DatatypeProperty ;
       rdfs:domain :PhysicalState ;
       rdfs:range xsd:decimal ;
       rdfs:label "depth"@en ,
                  "profondeur"@fr .


###  https://ontology.lotusim.org/naval-maritime#heading
:heading rdf:type owl:DatatypeProperty ;
         rdfs:domain :PhysicalState ;
         rdfs:range xsd:decimal ;
         rdfs:label "cap"@fr ,
                    "heading"@en .


###  https://ontology.lotusim.org/naval-maritime#historicalPeriod
:historicalPeriod rdf:type owl:DatatypeProperty ;
                  rdfs:domain :PhysicalObject ;
                  rdfs:range xsd:string ;
                  rdfs:label "historical period"@en ,
                             "période historique"@fr .


###  https://ontology.lotusim.org/naval-maritime#identifier
:identifier rdf:type owl:DatatypeProperty ;
            rdfs:domain :PhysicalEntity ;
            rdfs:range xsd:string ;
            rdfs:label "identifiant"@fr ,
                       "identifier"@en .


###  https://ontology.lotusim.org/naval-maritime#integrityStatus
:integrityStatus rdf:type owl:DatatypeProperty ;
                 rdfs:domain :SystemState ;
                 rdfs:range xsd:string ;
                 rdfs:label "integrity status"@en ,
                            "état d'intégrité"@fr .


###  https://ontology.lotusim.org/naval-maritime#latitude
:latitude rdf:type owl:DatatypeProperty ;
          rdfs:domain :PhysicalState ;
          rdfs:range xsd:decimal ;
          rdfs:label "latitude"@en ,
                     "latitude"@fr ;
          <http://www.w3.org/2004/02/skos/core#closeMatch> <http://www.w3.org/2003/01/geo/wgs84_pos#lat> .


###  https://ontology.lotusim.org/naval-maritime#longitude
:longitude rdf:type owl:DatatypeProperty ;
           rdfs:domain :PhysicalState ;
           rdfs:range xsd:decimal ;
           rdfs:label "longitude"@en ,
                      "longitude"@fr ;
           <http://www.w3.org/2004/02/skos/core#closeMatch> <http://www.w3.org/2003/01/geo/wgs84_pos#long> .


###  https://ontology.lotusim.org/naval-maritime#numericValue
:numericValue rdf:type owl:DatatypeProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :PropertyValue ;
              rdfs:range xsd:decimal ;
              rdfs:label "numeric value"@en ,
                         "valeur numérique"@fr .


###  https://ontology.lotusim.org/naval-maritime#operationalStatus
:operationalStatus rdf:type owl:DatatypeProperty ;
                   rdfs:domain :SystemState ;
                   rdfs:range xsd:string ;
                   rdfs:label "operational status"@en ,
                              "statut opérationnel"@fr .


###  https://ontology.lotusim.org/naval-maritime#pressure
:pressure rdf:type owl:DatatypeProperty ;
          rdfs:domain :EnvironmentalState ;
          rdfs:range xsd:decimal ;
          rdfs:label "pression"@fr ,
                     "pressure"@en .


###  https://ontology.lotusim.org/naval-maritime#salinity
:salinity rdf:type owl:DatatypeProperty ;
          rdfs:domain :EnvironmentalState ;
          rdfs:range xsd:decimal ;
          rdfs:label "salinity"@en ,
                     "salinité"@fr .


###  https://ontology.lotusim.org/naval-maritime#seaStateCode
:seaStateCode rdf:type owl:DatatypeProperty ;
              rdfs:domain :EnvironmentalState ;
              rdfs:range xsd:integer ;
              rdfs:label "code d'état de mer"@fr ,
                         "sea-state code"@en .


###  https://ontology.lotusim.org/naval-maritime#speed
:speed rdf:type owl:DatatypeProperty ;
       rdfs:domain :PhysicalState ;
       rdfs:range xsd:decimal ;
       rdfs:label "speed"@en ,
                  "vitesse"@fr .


###  https://ontology.lotusim.org/naval-maritime#temperature
:temperature rdf:type owl:DatatypeProperty ;
             rdfs:domain :EnvironmentalState ;
             rdfs:range xsd:decimal ;
             rdfs:label "temperature"@en ,
                        "température"@fr .


###  https://ontology.lotusim.org/naval-maritime#textValue
:textValue rdf:type owl:DatatypeProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :PropertyValue ;
           rdfs:range xsd:string ;
           rdfs:label "text value"@en ,
                      "valeur textuelle"@fr .


###  https://ontology.lotusim.org/naval-maritime#turbidity
:turbidity rdf:type owl:DatatypeProperty ;
           rdfs:domain :EnvironmentalState ;
           rdfs:range xsd:decimal ;
           rdfs:label "turbidity"@en ,
                      "turbidité"@fr .


###  https://ontology.lotusim.org/naval-maritime#unitSymbol
:unitSymbol rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :PropertyValue ;
            rdfs:range xsd:string ;
            rdfs:label "symbole d'unité"@fr ,
                       "unit symbol"@en .


###  https://ontology.lotusim.org/naval-maritime#validAtTime
:validAtTime rdf:type owl:DatatypeProperty ;
             rdfs:domain :PhysicalState ;
             rdfs:range xsd:dateTime ;
             rdfs:label "valid at time"@en ,
                        "valide à l'instant"@fr .


###  https://ontology.lotusim.org/naval-maritime#visibilityRange
:visibilityRange rdf:type owl:DatatypeProperty ;
                 rdfs:domain :EnvironmentalState ;
                 rdfs:range xsd:decimal ;
                 rdfs:label "portée de visibilité"@fr ,
                            "visibility range"@en .


#################################################################
#    Classes
#################################################################

###  http://www.opengis.net/ont/geosparql#Feature
<http://www.opengis.net/ont/geosparql#Feature> rdf:type owl:Class .


###  http://www.w3.org/ns/sosa/Actuator
<http://www.w3.org/ns/sosa/Actuator> rdf:type owl:Class .


###  http://www.w3.org/ns/sosa/Platform
<http://www.w3.org/ns/sosa/Platform> rdf:type owl:Class .


###  http://www.w3.org/ns/sosa/Sensor
<http://www.w3.org/ns/sosa/Sensor> rdf:type owl:Class .


###  https://ontology.lotusim.org/naval-maritime#AIAccelerator
:AIAccelerator rdf:type owl:Class ;
               rdfs:subClassOf :ComputingDevice .


###  https://ontology.lotusim.org/naval-maritime#AISTransceiver
:AISTransceiver rdf:type owl:Class ;
                rdfs:subClassOf :CommunicationDevice ,
                                :Sensor .


###  https://ontology.lotusim.org/naval-maritime#AcousticCommunication
:AcousticCommunication rdf:type owl:Class ;
                       rdfs:subClassOf :CommunicationCapability .


###  https://ontology.lotusim.org/naval-maritime#AcousticModem
:AcousticModem rdf:type owl:Class ;
               rdfs:subClassOf :CommunicationDevice .


###  https://ontology.lotusim.org/naval-maritime#AcousticPerception
:AcousticPerception rdf:type owl:Class ;
                    rdfs:subClassOf :PerceptionCapability .


###  https://ontology.lotusim.org/naval-maritime#AcousticSensor
:AcousticSensor rdf:type owl:Class ;
                rdfs:subClassOf :Sensor .


###  https://ontology.lotusim.org/naval-maritime#ActiveSonar
:ActiveSonar rdf:type owl:Class ;
             rdfs:subClassOf :AcousticSensor .


###  https://ontology.lotusim.org/naval-maritime#Actuator
:Actuator rdf:type owl:Class ;
          rdfs:subClassOf <http://www.w3.org/ns/sosa/Actuator> ,
                          :Equipment .


###  https://ontology.lotusim.org/naval-maritime#AirMobility
:AirMobility rdf:type owl:Class ;
             rdfs:subClassOf :MobilityCapability .


###  https://ontology.lotusim.org/naval-maritime#AirPlatform
:AirPlatform rdf:type owl:Class ;
             rdfs:subClassOf :Platform .


###  https://ontology.lotusim.org/naval-maritime#Aircraft
:Aircraft rdf:type owl:Class ;
          rdfs:subClassOf :AirPlatform .


###  https://ontology.lotusim.org/naval-maritime#AircraftWreck
:AircraftWreck rdf:type owl:Class ;
               rdfs:subClassOf :Wreck .


###  https://ontology.lotusim.org/naval-maritime#Airspace
:Airspace rdf:type owl:Class ;
          rdfs:subClassOf :SpatialRegion .


###  https://ontology.lotusim.org/naval-maritime#Altimeter
:Altimeter rdf:type owl:Class ;
           rdfs:subClassOf :NavigationSensor .


###  https://ontology.lotusim.org/naval-maritime#Anchor
:Anchor rdf:type owl:Class ;
        rdfs:subClassOf :ArtificialObject .


###  https://ontology.lotusim.org/naval-maritime#AquacultureFacility
:AquacultureFacility rdf:type owl:Class ;
                     rdfs:subClassOf :OffshoreInfrastructure .


###  https://ontology.lotusim.org/naval-maritime#ArtificialObject
:ArtificialObject rdf:type owl:Class ;
                  rdfs:subClassOf :PhysicalObject .


###  https://ontology.lotusim.org/naval-maritime#AssessmentCapability
:AssessmentCapability rdf:type owl:Class ;
                      rdfs:subClassOf :DataProcessingCapability .


###  https://ontology.lotusim.org/naval-maritime#Atmosphere
:Atmosphere rdf:type owl:Class ;
            rdfs:subClassOf :PhysicalMedium .


###  https://ontology.lotusim.org/naval-maritime#AutonomousUnderwaterVehicle
:AutonomousUnderwaterVehicle rdf:type owl:Class ;
                             rdfs:subClassOf :UncrewedUnderwaterVehicle .


###  https://ontology.lotusim.org/naval-maritime#BallastSystem
:BallastSystem rdf:type owl:Class ;
               rdfs:subClassOf :Actuator .


###  https://ontology.lotusim.org/naval-maritime#Balloon
:Balloon rdf:type owl:Class ;
         rdfs:subClassOf :AirPlatform .


###  https://ontology.lotusim.org/naval-maritime#Battery
:Battery rdf:type owl:Class ;
         rdfs:subClassOf :EnergyDevice .


###  https://ontology.lotusim.org/naval-maritime#Beacon
:Beacon rdf:type owl:Class ;
        rdfs:subClassOf :NavigationInfrastructure .


###  https://ontology.lotusim.org/naval-maritime#Boat
:Boat rdf:type owl:Class ;
      rdfs:subClassOf :SurfacePlatform .


###  https://ontology.lotusim.org/naval-maritime#Bomb
:Bomb rdf:type owl:Class ;
      rdfs:subClassOf :UnexplodedOrdnance .


###  https://ontology.lotusim.org/naval-maritime#BottomMine
:BottomMine rdf:type owl:Class ;
            rdfs:subClassOf :NavalMine .


