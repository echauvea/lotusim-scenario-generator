                 :hasUsageDomain :CivilUse .


###  https://ontology.lotusim.org/naval-maritime#SurfacingCapability
:SurfacingCapability rdf:type owl:NamedIndividual ;
                     :hasUsageDomain :DualUse .


###  https://ontology.lotusim.org/naval-maritime#SurveyCapability
:SurveyCapability rdf:type owl:NamedIndividual ;
                  :hasUsageDomain :DualUse .


###  https://ontology.lotusim.org/naval-maritime#SystemModel
:SystemModel rdf:type owl:NamedIndividual ;
             :hasUsageDomain :CivilUse .


###  https://ontology.lotusim.org/naval-maritime#SystemState
:SystemState rdf:type owl:NamedIndividual ;
             :hasUsageDomain :CivilUse .


###  https://ontology.lotusim.org/naval-maritime#TargetFollowingCapability
:TargetFollowingCapability rdf:type owl:NamedIndividual ;
                           :hasUsageDomain :DualUse .


###  https://ontology.lotusim.org/naval-maritime#Thermocline
:Thermocline rdf:type owl:NamedIndividual ;
             :hasUsageDomain :CivilUse .


###  https://ontology.lotusim.org/naval-maritime#ThreatAssessmentCapability
:ThreatAssessmentCapability rdf:type owl:NamedIndividual ;
                            :hasUsageDomain :MilitaryUse .


###  https://ontology.lotusim.org/naval-maritime#Tide
:Tide rdf:type owl:NamedIndividual ;
      :hasUsageDomain :CivilUse .


###  https://ontology.lotusim.org/naval-maritime#Torpedo
:Torpedo rdf:type owl:NamedIndividual ;
         :hasUsageDomain :MilitaryUse .


###  https://ontology.lotusim.org/naval-maritime#TrackingCapability
:TrackingCapability rdf:type owl:NamedIndividual ;
                    :hasUsageDomain :DualUse .


###  https://ontology.lotusim.org/naval-maritime#TransportCapability
:TransportCapability rdf:type owl:NamedIndividual ;
                     :hasUsageDomain :DualUse .


###  https://ontology.lotusim.org/naval-maritime#UncrewedAerialVehicle
:UncrewedAerialVehicle rdf:type owl:NamedIndividual ;
                       :hasUsageDomain :DualUse .


###  https://ontology.lotusim.org/naval-maritime#UncrewedSurfaceVehicle
:UncrewedSurfaceVehicle rdf:type owl:NamedIndividual ;
                        :hasUsageDomain :DualUse .


###  https://ontology.lotusim.org/naval-maritime#UncrewedUnderwaterVehicle
:UncrewedUnderwaterVehicle rdf:type owl:NamedIndividual ;
                           :hasUsageDomain :DualUse .


###  https://ontology.lotusim.org/naval-maritime#UnderwaterGlider
:UnderwaterGlider rdf:type owl:NamedIndividual ;
                  :hasUsageDomain :CivilUse .


###  https://ontology.lotusim.org/naval-maritime#UnderwaterMobility
:UnderwaterMobility rdf:type owl:NamedIndividual ;
                    :hasUsageDomain :CivilUse .


###  https://ontology.lotusim.org/naval-maritime#UnderwaterPlatform
:UnderwaterPlatform rdf:type owl:NamedIndividual ;
                    :hasUsageDomain :CivilUse .


###  https://ontology.lotusim.org/naval-maritime#UnexplodedOrdnance
:UnexplodedOrdnance rdf:type owl:NamedIndividual ;
                    :hasUsageDomain :MilitaryUse .


###  https://ontology.lotusim.org/naval-maritime#UnidentifiedDebris
:UnidentifiedDebris rdf:type owl:NamedIndividual ;
                    :hasUsageDomain :CivilUse .


###  https://ontology.lotusim.org/naval-maritime#UsageDomain
:UsageDomain rdf:type owl:NamedIndividual ;
             :hasUsageDomain :CivilUse .


###  https://ontology.lotusim.org/naval-maritime#VegetationMass
:VegetationMass rdf:type owl:NamedIndividual ;
                :hasUsageDomain :CivilUse .


###  https://ontology.lotusim.org/naval-maritime#Warship
:Warship rdf:type owl:NamedIndividual ;
         :hasUsageDomain :MilitaryUse .


###  https://ontology.lotusim.org/naval-maritime#WaterColumn
:WaterColumn rdf:type owl:NamedIndividual ;
             :hasUsageDomain :CivilUse .


###  https://ontology.lotusim.org/naval-maritime#WaterVolume
:WaterVolume rdf:type owl:NamedIndividual ;
             :hasUsageDomain :CivilUse .


###  https://ontology.lotusim.org/naval-maritime#Wave
:Wave rdf:type owl:NamedIndividual ;
      :hasUsageDomain :CivilUse .


###  https://ontology.lotusim.org/naval-maritime#WaypointNavigationCapability
:WaypointNavigationCapability rdf:type owl:NamedIndividual ;
                              :hasUsageDomain :CivilUse .


